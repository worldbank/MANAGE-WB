 1.67656        1.49854        1.51875        1.8071         1.50689        1.325          1.48354        1.94811        1.50319        1.65883        1.67289        1.45958        1.76951        1.26646        1.50142        1.63319        1.60883        1.63603        1.52386        1.6402         1.33088        1.57075        1.31282        1.46638        1.50237        1.21937        1.47574        1.14956
    c-DWE_i          1.09018        1.1211         1.1949         1.40453        1.12231        1.126          1.1482         1.44321        1.11206        1.24391        1.53547        1.41703        1.69078        1.27605        1.37849        1.13752        1.31772        1.53872        1.22659        1.4985         1.47275        1.70951        1.35764        1.5592         1.40384        1.41695        1.47373        1.10995        1.07549        1.25289        1.07219        1.14335        1.4054         1.22218        1.19577        1.23399        1.2852         1.37323        1.51373        1.18476        1.21486        1.28666        1.19239        1.38803        1.49941        1.57621        1.18792        1.46416        1.48846        1.36665        1.25964        4.70188        1.04789        1.26371        1.29893        1.15558        1.20635        1.32345        1.31101        1.14116        1.29709        1.23836        1.29054        1.14622        1.1635         1.18147        1.20659        1.25619        1.28905        1.13144        1.28211        1.27377        1.00312        1.13499        1.20545        1.26581        1.18335        1.33108        1.30851        1.21503        1.13393        1.21781        1.08732        1.23821        1.10689        1.1046         1.36703        1.30289        1.60963        1.23038        1.41518        1.44595        1.27051        1.28123        1.6245         1.51568        1.53298        1.3063         1.55175        1.35557        1.43589        1.1543         1.36966        1.26742        1.15047        1.31404        1.16835        1.14521        1.22445        1.29731        1.33605        1.29441        1.37047        1.2799         1.16184        1.31153        1.87729        1.4459         1.56941        1.41825        2.07286        1.78558        1.49378        1.45691        1.65797        1.89587        1.75696        1.52219        1.41693        1.48372        1.6823         1.73712        1.67656        1.49854        1.51875        1.8071         1.50689        1.325          1.48354        1.94811        1.50319        1.65883        1.67289        1.45958        1.76951        1.26646        1.50142        1.63319        1.60883        1.63603        1.52386        1.6402         1.33088        1.57075        1.31282        1.46638        1.50237        1.21937        1.47574        1.14956
   ;

*
*  --- read demand nesting and mapping to proto-SAM
*

   set c0(*),cc(*,*);

   $$onEmbeddedCode Python:

     c0 = []
     cc = []
     c  = gams.get('c')
     for s in c:
        i = s.index('_i')
        c0.append(s[:i])
        cc.append((s[:i],s))

     gams.set("c0",c0)
     gams.set("cc",cc)

   $$offEmbeddedCode c0 cc

   $$iftheni.GtapCE "%sysEnv.GTAPCE%"=="on"
*
*  ---- copy over demand system parameters
*
    set oxt /c-nmn_i,c-mio_i,c-mao_i,c-mcu_i,c-moo_i/;
    set chm /c-kfr_i,c-nfr_i,c-pfr_i,c-xch_i,c-rbr_i,c-plp_i,c-pls_i,c-plr_i,c_plt_i/;
    set nmm /c-cem_i,c-nmx_i/;
    set i_s /c-i_s isp_i,c-iss_i,c-ris_i,c-isc_i/;
    set nfm /c-app_i,c-aps_i,c-ral_i,c-cpp_i,c-cps_i,c-rcp_i,c-mpp_i,c-mps_i,c-rom_i,c-nfc_i,c_cop_i,c_alu_i,c_i_s_i/;

    incp(oxt,reg) = incp("c-oxt_i",reg);
    incp(chm,reg) = incp("c-chm_i",reg);
    incp(nmm,reg) = incp("c-nmm_i",reg);
    incp(i_s,reg) = incp("c-i_s_i",reg);
    incp(nfm,reg) = incp("c-nfm_i",reg);

    subp(oxt,reg) = subp("c-oxt_i",reg);
    subp(chm,reg) = subp("c-chm_i",reg);
    subp(nmm,reg) = subp("c-nmm_i",reg);
    subp(i_s,reg) = subp("c-i_s_i",reg);
    subp(nfm,reg) = subp("c-nfm_i",reg);


 $$endif.GTAPCE
*
*  --- Template for GTAP power comprises the product c-ely as an aggreate of the
*      the different power products below. Aggregate demand parameters accordingly
*
   cc("c-ely",c) $ sum(c_cg(c,elyCG),1)  = YES;

   parameter mapKNestShr(*,*);
   set k(*);
   $$GDXIN '%gams.scrdir%fromTemplate.gdx'
     $$LOAD k<mapKNestShr.dim2
     $$LOAD mapkNestShr
   $$GDXIN
   alias(k,kk);
*
* --- aggregate CDE demand system parameters according to demand nesting
*
   mapKNestShr(c,k) = sum(cc(c0,c), mapKNestShr(c0,k));

   parameter xkShr(k,reg) "Budget shares for demand nests";
   xkShr(k,reg)                              = sum((c,h), mapKNestShr(c,k)*samFin(c,h,reg));

   $$iftheni.regname not "%regName%"==""
*
*    --- delete values to calculate CDE demand system parameters for regions for which
*        no further calculations are needed

     subp(c,reg)  $ (not sameas(reg,"%regName%")) = 0;
     incp(c,reg)  $ (not sameas(reg,"%regName%")) = 0;
     xkShr(k,reg) $ (not sameas(reg,"%regName%")) = 0;
   $$endif.regname
*
*  --- this is not perfect, but works for up to three levels of final demand nests
*
   xkShr(k,reg) $ sum(kk,mapKNestShr(kk,k))  = sum(kk,    mapKNestShr(kk,k)*xkShr(kk,reg));
   xkShr(k,reg) $ sum(kk,mapKNestShr(kk,k))  = sum(kk,    mapKNestShr(kk,k)*xkShr(kk,reg));
   xkShr(k,reg) $ sum(kk,mapKNestShr(kk,k))  = sum(kk,    mapKNestShr(kk,k)*xkShr(kk,reg));
*
*  --- first define bottom nest parameters from products, then aggregate from sub-nests
*      to mother nests. Again, works for up to three levels of final demand nests
*
   subp(k,reg)  $ xkShr(k,reg)
      = sum((c,h), mapKNestShr(c,k)*samFin(c,h,reg)*subp(c,reg))/xkshr(k,reg);

   subp(k,reg) $ (sum(kk,mapKNestShr(kk,k)) $ xkShr(k,reg))
      = sum(kk,    mapKNestShr(kk,k)*xkShr(kk,reg)*subp(kk,reg))/xkShr(k,reg);
   subp(k,reg) $ (sum(kk,mapKNestShr(kk,k)) $ xkShr(k,reg))
      = sum(kk,    mapKNestShr(kk,k)*xkShr(kk,reg)*subp(kk,reg))/xkShr(k,reg);
   subp(k,reg) $ (sum(kk,mapKNestShr(kk,k)) $ xkShr(k,reg))
      = sum(kk,    mapKNestShr(kk,k)*xkShr(kk,reg)*subp(kk,reg))/xkShr(k,reg);

   incp(k,reg)  $ xkShr(k,reg)
      = sum((c,h), mapKNestShr(c,k)*samFin(c,h,reg)*incp(c,reg))/xkshr(k,reg);

   incp(k,reg) $ (sum(kk,mapKNestShr(kk,k)) $ xkShr(k,reg))
      = sum(kk,    mapKNestShr(kk,k)*xkShr(kk,reg)*incp(kk,reg))/xkShr(k,reg);
   incp(k,reg) $ (sum(kk,mapKNestShr(kk,k)) $ xkShr(k,reg))
      = sum(kk,    mapKNestShr(kk,k)*xkShr(kk,reg)*incp(kk,reg))/xkShr(k,reg);
   incp(k,reg) $ (sum(kk,mapKNestShr(kk,k)) $ xkShr(k,reg))
      = sum(kk,    mapKNestShr(kk,k)*xkShr(kk,reg)*incp(kk,reg))/xkShr(k,reg);

*
*  --- delete parameters for non-top level nest and individual products
*
   incp(k,reg) $ sum(kk $ mapKNestShr(k,kk), incp(k,reg) ) = 0;
   subp(k,reg) $ sum(kk $ mapKNestShr(k,kk), subp(k,reg) ) = 0;

   incp(c,reg) = 0;
   subp(c,reg) = 0;
   xkShr(k,reg) $ xkShr(k,reg) = xkShr(k,reg)/sum(kk,xkShr(kk,reg));
   xkShr(k,reg) $ sum(kk $ mapKNestShr(k,kk), xkShr(k,reg) ) = 0;
*
*  --- define income elasticities for all regions
*
   parameter incElas(reg,k);

   incElas(reg,k) $  xkShr(k,reg)  = (incp(k,reg)*subp(k,reg)-sum(kk, xkshr(kk,reg)*incp(kk,reg)*subp(kk,reg)))

            /  sum(kk, xkshr(kk,reg)*incp(kk,reg))
            -  (subp(k,reg) - 1) + sum(kk, xkshr(kk,reg)*subp(kk,reg));

*-------------------------------------------------------------------------------
*
*  Final output to GDX
*
*-------------------------------------------------------------------------------

  $$iftheni.regname "%regName%"==""
*
*    --- a run for all countries: output SAms for all regions, global average cost shares
*        income elasticities, and GDP
*
      parameter pop(reg);
      pop(reg) = sum(cohorts,unPop(reg,cohorts,"2017"));

      parameter gdp;
      gdp(reg) $ pop(reg)
         =[  sum( (c,i), samFin(c,i,reg))
                 + sum( (c,g), samFin(c,g,reg))
                 + sum( (c,h), samFin(c,h,reg))
                 + sum( (c,w), samFin(c,w,reg))
                 - sum( (w,c), samFin(w,c,reg))]/pop(reg)*1000;

     incElas(reg,k) $ (not pop(reg)) = 0;
     incp(k,reg)    $ (not pop(reg)) = 0;
     subp(k,reg)    $ (not pop(reg)) = 0;

     execute_unload 'sav/gtapSUTV%version%.gdx', samFin,avgCostShare,incElas,incp,subp,gdp;

  $$else.regName
*
*    --- single region run: generate SAM in EXCEL and bridgefile
*

     parameter hohPar(*,*,k);
*
*    --- define income and own price elasticities for top level nests and aggregate household
*

     hohPar("h-hhold","incElas0",k) $  xkshr(k,"%regName%")
       = (incp(k,"%regName%")*subp(k,"%regName%")-sum(kk, xkshr(kk,"%regName%")*incp(kk,"%regName%")*subp(kk,"%regName%")))

              /  sum(kk, xkshr(kk,"%regName%")*incp(kk,"%regName%"))
              -  (subp(k,"%regName%") - 1) + sum(kk, xkshr(kk,"%regName%")*subp(kk,"%regName%"));

     hohPar("h-hhold","prcElas0",k) $  xkshr(k,"%regName%")
       = (1-subp(k,"%regName%"))*(xkshr(k,"%regName%")-1)
             -   xkshr(k,"%regName%")*(subp(k,"%regName%") + hohPar("h-hhold","incElas0",k)
             -   sum(kk, xkshr(kk,"%regName%")*subp(kk,"%regName%")));

     Parameter p_SAM0(sac0,sac0) ;
*    p_SAM0(sac0,sac00) = sum((sac0_sac(sac0,sac),sacp) $ (sac0_sac(sac00,sacp) $ (abs(p_protoSam(sac,sacp)) gt 1.E-20)),p_protoSam(sac,sacp));
     p_SAM0(sac0,sac00) = sum((sac0_sac(sac0,sac),sacp) $ sac0_sac(sac00,sacp),p_protoSam(sac,sacp));
*
*    --- define power mix in base year
*
     $$ifthen.GtapPow "%sysEnv.GTAPPower%"=="on"

     set aElec(aFin) /
         a-NuclearBL
         a-CoalBL
         a-GasBL
         a-WindBL
         a-HydroBL
         a-OilBL
         a-OtherBL
         a-GasP
         a-HydroP
         a-OilP
         a-SolarP
     /;
     $$else.GTAPPow
     set aElec(aFin) / a-ely /;

     $$endif.GTAPPow
     alias(aElec,aElec1);
*
*    --- define base year power mix
*
     parameter p_powerMix(*,*,projYears);
     p_powerMix("bas",aElec,projYears) = sum((afin_a(aElec,a),c),p_protoSam(a,c));
     p_powerMix("bas",aElec,projYears) $ p_powerMix("bas",aElec,projYears)
       = p_powerMix("bas",aElec,projYears)/sum(aElec1,p_powerMix("bas",aElec1,projYears));
*
*    --- introduce a constant electricity price projection (for overwriting)
*
     p_powerMix("bas","elecPrice",projYears) = 1;
*
*    --- input a projection of demand for transport services and their energy demands
*
     set aTrans(aFin) "Transport sectors"/
         a-otp
         a-otpEle
         a-wtp
         a-atp
     /;

     set iEner(*)    / c-oil,c-p_c,c-gas,c-gdt,c-tnd,c-ely /;
     set iEnerOut    / c-oil,c-p_c,gas_gdt,ely_tnd /;
     alias(iEner,iEner1);

     parameter p_incElasTrs(aTrans);
     p_incElasTrs(aTrans) = hohPar("h-hhold","incElas0","trans");

     parameter p_energyProj(*,*,*,projYears),p_shareHsldDemand(aFin),p_shareEnerTransport(*,aFin);
*
*    --- Define share of household demand in total transport demand at benchmark, defines
*        weight of income elasticity in projecting economy-wide transport demands
*
     p_shareHsldDemand("a-otp")    = sum(h,p_protoSam("c-otp_i",h))/sum(sac,p_protoSam("c-otp_i",sac));
     p_shareHsldDemand("a-otpEle") = sum(h,p_protoSam("c-otpEle_i",h))/sum(sac,p_protoSam("c-otpEle_i",sac));
     p_shareHsldDemand("a-wtp")    = sum(h,p_protoSam("c-wtp_i",h))/sum(sac,p_protoSam("c-wtp_i",sac));
     p_shareHsldDemand("a-atp")    = sum(h,p_protoSam("c-atp_i",h))/sum(sac,p_protoSam("c-atp_i",sac));
*
*    --- Define share of energy carriers in total energy demand of transport services
*
     p_shareEnerTransport(iEner,aTrans)   = sum((cc(iEner,c),afin_a(aTrans,a)),p_protoSam(c,a));
     p_shareEnerTransport(iEner,aTrans) $ p_shareEnerTransport(iEner,aTrans)
       = p_shareEnerTransport(iEner,aTrans)/sum(iEner1,p_shareEnerTransport(iEner1,aTrans));
*
*    --- project transport demands based on GDP growth and income elaticities
*        for non-household demands, projection follows GDP growth
*
     p_energyProj("BAU","demand",aTrans,projYears) = 1;
     loop(projYears $ (projYears.pos gt 1),

        p_energyProj("BAU","demand",aTrans,projYears)
         = p_energyProj("BAU","demand",aTrans,projYears-1)
            + p_energyProj("BAU","demand",aTrans,projYears-1)
                *  mfmodGDP(projYears,"%regName%")/100 * (p_incElasTrs(aTrans) * p_shareHsldDemand(aTrans)+ 1-p_shareHsldDemand(aTrans));
     );
*
*    --- projection for total enery demand of transport service, assume 0.25% energy savings per year
*
     p_energyProj("BAU","ener",aTrans,projYears)      = p_energyProj("BAU","demand",aTrans,projYears) * 0.9975**(projYears.pos-1);
     p_energyProj("BAU","nrgFac",aFin,projYears) $ (not aTrans(aFin)) = 1.005**(projYears.pos-1);
*
*    --- derived projection of enery demands: energy demand projections, 0.25% less petroleum/coke and oil p.a., offset by
*        increase in gas and electricity
*

     p_energyProj("BAU","c-p_c","a-otp",projYears)  = p_energyProj("BAU","ener","a-otp",projYears) * 0.995**(projYears.pos-1);
     p_energyProj("BAU","c-oil","a-otp",projYears)  = p_energyProj("BAU","ener","a-otp",projYears) * 0.995**(projYears.pos-1);

     p_energyProj("BAU","c-p_c","a-wtp",projYears)  = p_energyProj("BAU","ener","a-wtp",projYears) * 0.998**(projYears.pos-1);
     p_energyProj("BAU","c-oil","a-wtp",projYears)  = p_energyProj("BAU","ener","a-wtp",projYears) * 0.998**(projYears.pos-1);

     p_energyProj("BAU","c-p_c","a-atp",projYears)  = p_energyProj("BAU","ener","a-atp",projYears) * 0.999**(projYears.pos-1);
     p_energyProj("BAU","c-oil","a-atp",projYears)  = p_energyProj("BAU","ener","a-atp",projYears) * 0.999**(projYears.pos-1);

     p_energyProj("BAU",iEnerOut,aTrans,projYears) $ ((not (sameas(iEnerOut,"c-p_c") or sameas(iEnerOut,"c-oil")))
                                                       $ (1-p_shareEnerTransport("c-p_c",aTrans)-p_shareEnerTransport("c-oil",aTrans)))
       = p_energyProj("BAU","ener",aTrans,projYears)*(1 + (1-p_energyProj("BAU",aTrans,"c-p_c",projYears)/p_energyProj("BAU","ener",aTrans,projYears))
                                                               *(p_shareEnerTransport("c-p_c",aTrans)+p_shareEnerTransport("c-oil",aTrans))
                                                               /(1-p_shareEnerTransport("c-p_c",aTrans)-p_shareEnerTransport("c-oil",aTrans)));
*
*    --- fossil fuel price projections as used in Romania CCDR
*
     set fossilSim / Bau,NZ /;
     set fossilC   / c-coa,c-oil,c-gas,c-p_c /;

     table p_fossilPrices(fossilSim,*,projYears)

                         2020      2021      2022      2023      2024      2025      2026      2027      2028      2029      2030      2031      2032      2033      2034      2035      2036      2037      2038      2039      2040      2041      2042      2043      2044      2045      2046      2047      2048      2049      2050
     bau.      c-coa     67.8      147.9     344.9     231.7     200.8     181.6     162.5     143.3     124.2     105.0     85.9      84.6      83.4      82.2      81.0      79.8      79.4      79.1      78.8      78.4      78.1      77.6      77.1      76.6      76.1      75.6      75.5      75.4      75.3      75.2      75.1
     bau.      c-oil     47.2      75.5      99.8      88.8      75.7      77.7      79.7      81.7      83.8      85.8      87.8      88.3      88.7      89.1      89.5      90.0      90.8      91.7      92.5      93.4      94.3      94.8      95.3      95.9      96.4      96.9      97.9      98.9      99.8      100.8     101.8
     bau.      c-gas     2.2       4.1       6.4       6.0       5.7       5.4       5.2       5.0       4.7       4.5       4.3       4.3       4.3       4.3       4.4       4.4       4.4       4.4       4.5       4.5       4.5       4.5       4.5       4.6       4.6       4.6       4.7       4.8       4.9       4.9       5.0

     NZ.       c-coa     67.8     147.9     344.9     231.7     200.8      177.4     154.0     130.5     107.1     83.7      60.3      59.7      59.2      58.6      58.0      57.4      56.8      56.2      55.6      55.0      54.4      53.9      53.3      52.7      52.1      51.5      50.9      50.3      49.7      49.1      48.6
     NZ.       c-oil     47.2     75.5      99.8      88.8      75.7       68.9      62.1      55.3      48.6      41.8      35.0      34.5      33.9      33.4      32.8      32.3      31.7      31.2      30.6      30.1      29.5      29.0      28.4      27.9      27.3      26.8      26.2      25.7      25.1      24.6      24.0
     NZ.       c-gas     2.2      4.1       6.4       6.0       5.7        5.4       5.1       4.8       4.5       4.2       4.0       3.9       3.8       3.7       3.6       3.5       3.4       3.3       3.2       3.1       3.0       3.0       2.9       2.9       2.8       2.8       2.8       2.8       2.8       2.8       2.8
     ;

     set missProjYears(projYears) / %baseYear%*2019 /;

*
*    --- no change from 2017-2020, petroleum and coke follows oil
*
     p_fossilPrices(fossilSim,fossilC,missProjYears) = p_fossilPrices(fossilSim,fossilC,"2020");
*
     p_fossilPrices(fossilSim,"c-p_c",projYears)     = p_fossilPrices(fossilSim,"c-oil",projYears);
*
*    --- some assumed energy price carry-overs
*
     p_fossilPrices(fossilSim,"c-atp",projYears)     = 1 + [p_fossilPrices(fossilSim,"c-oil",projYears)/p_fossilPrices(fossilSim,"c-oil","2020")-1]*0.2;
     p_fossilPrices(fossilSim,"c-otp",projYears)     = 1 + [p_fossilPrices(fossilSim,"c-oil",projYears)/p_fossilPrices(fossilSim,"c-oil","2020")-1]*0.2;
     p_fossilPrices(fossilSim,"c-wtp",projYears)     = 1 + [p_fossilPrices(fossilSim,"c-oil",projYears)/p_fossilPrices(fossilSim,"c-oil","2020")-1]*0.2;
     p_fossilPrices(fossilSim,"c-ely",projYears)     = 1 + [p_fossilPrices(fossilSim,"c-oil",projYears)/p_fossilPrices(fossilSim,"c-oil","2020")-1]*0.4;
     p_fossilPrices(fossilSim,"c-gtd",projYears)     = 1 + [p_fossilPrices(fossilSim,"c-gas",projYears)/p_fossilPrices(fossilSim,"c-gas","2020")-1]*0.2;
     p_fossilPrices(fossilSim,"c-nmm",projYears)     = 1 + [p_fossilPrices(fossilSim,"c-oil",projYears)/p_fossilPrices(fossilSim,"c-oil","2020")-1]*0.2;
     p_fossilPrices(fossilSim,"c-i_s",projYears)     = 1 + [p_fossilPrices(fossilSim,"c-oil",projYears)/p_fossilPrices(fossilSim,"c-oil","2020")-1]*0.2;
     p_fossilPrices(fossilSim,"c-nfm",projYears)     = 1 + [p_fossilPrices(fossilSim,"c-oil",projYears)/p_fossilPrices(fossilSim,"c-oil","2020")-1]*0.2;
*
*    --- copy to transport projection
*
     p_energyProj(fossilsim,"pwm",fossilC,projYears) = p_fossilPrices(fossilSim,fossilC,projYears);
*
*    --- load nutrient data
*
     set nutr / cal,prot,fat /;
     parameter p_nutrients(rg,*,nutr),p_nutout(*,nutr);
     execute_load "dat/%version%.gdx" p_nutrients;
     p_nutout(cfin,nutr)     = sum(cfin_cg(cfin,cg), p_nutrients("%regName%",cg,nutr));
     p_nutout("sum",nutr) = p_nutrients("%regName%","sum",nutr);
*
*    --- GDP Composition
*
     parameter gdpComp;
     gdpComp("Bas","GovCons",projYears) = sum((c,g),p_protoSam(c,g))/macro("tgdpmp2");
     gdpComp("Bas","netExp",projYears)  = [ + sum( (c,w), samFin(c,w,"%regName%"))
                                            - sum( (w,c), samFin(w,c,"%regName%"))]/macro("tgdpmp2");

     gdpComp("Bas","savf",projYears)    = [ + sum( (i,w),    samFin(i,w,"%regName%"))
                                            - samFin(w,"debt_i","%regName%")]/macro("tgdpmp2");;

     set aagr(*),mapaAgr(*,*);
     $$GDXIN '%gams.scrdir%fromTemplate.gdx'
       $$LOAD aagr<mapaAgr.dim1
       $$LOAD mapaAgr
     $$GDXIN

     gdpComp("Bas",aagr,projYears)
      = sum((mapaAgr(aagr,afin),afin_a(afin,a)), sum(f, samFin(f,a,"%regName%")))/sum((f,a),samFin(f,a,"%regName%"));
*
*    --- GDP growth rate
*
     gdpComp("bas","GDP",projYears) = mfmodGDP(projYears,"%regName%");
     gdpComp("bas","GDP",projYears) $ (not sum(projYears1,mfmodGDP(projYears1,"%regName%"))) = 2;
*
*    --- copy symbols to exports to temp. GDX
*
     $$ifi not defined labor0 labor0(regAct,"f-tech_aspros_0","a-pdr_0") = 1.E-20;


     alias(inst,inst1);
     parameter xfmSupDistr(inst,fFin,aFin);



     xfmSupDistr(inst,fFin,aFin) $ sum((inst_sac(inst,sac),fFin_f(fFin,f)),samFin(sac,f,"%regName%"))
        = sum((inst_sac(inst,sac),fFin_f(fFin,f)),samFin(sac,f,"%regName%"))/sum((inst_sac(inst1,sac),fFin_f(fFin,f)),samFin(sac,f,"%regName%")) + eps;
     display xfmSupDistr;
     option kill=xfmSupDistr;

     execute_unload '%gams.scrdir%/SAM_GTAP.gdx', p_protoSam,sac,acm_sac,p_macroSam,defPar,actPar,macro,hohpar,
                                                  p_powerMix,p_energyProj,p_sam0,p_nutout,gdpComp,labor0,xfmSupDistr;

     $$batinclude "inc/title.inc" '" %regName%: Update bridgefile in EXCEL"'
     $$onEcho > '%gams.scrdir%/howToWrite1.txt'
        par=defPar          rng=defPar!B2    rdim=1
        par=actPar          rng=actPar!A1    rdim=1 cdim=2
        par=hohpar          rng=hohPar!B9    rdim=1 cdim=2
        par=p_powerMix      rng=powerMix!A1  rdim=2 cdim=1
        par=p_energyProj    rng=energy!A1    rdim=3 cdim=1
        par=p_sam0          rng=SAM!A1
        par=p_nutout        rng=nutrients!A1
        par=gdpComp         rng=gdpComposition!A1
        par=labor0          rng=labor!A1     rDim=2 cDim=1
        par=xfmSupDistr     rng=hohPar!B15   rdim=2 cdim=1
     $$offecho
     execute 'GDXXRW.EXE input=%gams.scrdir%/SAM_GTAP.gdx O=reg/%regName%/BaseBridge_%regName%_%bridgeFile%.xlsx @%gams.scrdir%/howToWrite1.txt'

     $$batinclude "inc/title.inc" '" %regName%: Update proto-SAM, Macro-Sam and Macro sheets in EXCEL"'
     $$onEcho > '%gams.scrdir%/howToWrite2.txt'
        par=p_protoSAM      rng=Proto-Sam!A1 rdim=1 cdim=1
        par=p_macroSam      rng=Macro-Sam!A3 rdim=1 cdim=1
        par=macro           rng=macro!A6     rdim=1
     $$offecho
     execute 'GDXXRW.EXE input=%gams.scrdir%/SAM_GTAP.gdx O=reg/%regName%/SAM_%regName%_GTAP.xlsx par=macro  @%gams.scrdir%/howToWrite2.txt'
*
*    --- generate SIM directory if not existing and copy shock template files
*
     $$ifthen.newDir not dexist "reg/%regName%/sim"
        $$call mkdir "reg%system.dirsep%%regName%%system.dirsep%sim"
     $$endif.newDir
     $$ifthen.noShock not exist "reg/%regName%/sim/none.inc"
        $$call "cp   inc%system.dirsep%shockfiles%system.dirsep%*.inc  %curDir%\reg%system.dirsep%%regName%%system.dirsep%sim"
        $$call "copy inc%system.dirsep%shockfiles%system.dirsep%*.inc  %curDir%\reg%system.dirsep%%regName%%system.dirsep%sim"
     $$endif.noShock
  $$endif.regName
$if not errorfree $abort Compilation error after file: %system.fn%
if ( execerror, abort "Run-Time error in file: %system.fn%, line: %system.incline%");
