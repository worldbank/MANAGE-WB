********************************************************************************
$ontext

   MANAGE project

   GAMS file : GTAPSAMV6.GMS

   @purpose  : prepare GTAP SAM
   @author   :
   @date     : 03.03.23
   @since    :
   @refDoc   :
   @seeAlso  :
   @calledBy :

$offtext
********************************************************************************
  $$offlisting
  $$onglobal
  $$setglobal pgmName gtapSAMv6

* --- read in external debt data
*$call gdxxrw.exe "dat/debtData.xlsx" par=debtData rng=DataManage!A2:D6500 rDim=3 cDim=0
*
* ---- read information from interface
*
  $$include 'fromGuiToRun.gms'
  $$include 'inc/title_def.inc'

  Parameter ifHPD "use HPD to remove small balances" /0/;

  $$batinclude "inc/title.inc" '" %regName%: Define initial SAM from GTAP global sam"'

  set dummy / cgds /;
*
* --- Read basic GTAP sets
*
  set ag  "GTAP acitivities"
      cg  "GTAP commodities"
      fg  "GTAP endowments"
      rg  "GTAP regions"
      s_aez "GTAP regions"
  ;
  $$GDXIN "dat/%version%.gdx"
     $$LOAD ag,cg,fg,rg,s_aez=aez
  $$GDXIN
  alias(reg,rg);

  $$iftheni.careEcon "%careEcon%"=="on"
     $$ifi "%buildGender%"=="off" $$abort "Care-Economy account requires gender differentiated labor accounts"
  $$endif.careEcon

$ontext
  scalar block /0/,count/1/;
  file totest / "gui/totest.txt" /;
  put toTest;
  loop(rg $ (ord(rg.tl,1) ne )
     if ( mod(count,10) eq 1,
        block = block + 1;
        put / 'macro = regs',block:0:0,' ':0;
     );
     put rg.tl:0,' \ ':0;
     count = count+1;
  );
  put /;
  put 'macro reg = ';
  count = block;
  for(block = 1 to count,
     put '%regs':0,block:0:0'% ':0;
  );
  put /;

  putclose;
  $$exit
$offtext
  $$onmulti
  set ag / ctlRais "Cattle raising activity",otpEle "Other transport electrified",care "Care economy",macc "Marginal abatement cost services"/;
  set cg / ctlRais "Young cattle raised",    otpEle "Other transport electrified",care "Care economy",macc "Marginal abatement cost services"/;

  set fg / set.s_aez,water /;
  set aez(fg) / set.s_aez /;
*
* --- gender differentiated labor in case the old Gender Data base from V10 needs to be used (missing country information)
*
  set fg / m_skl,f_skl,m_nsk,f_nsk/;
*
* --- gender differentiated labor in case of the new ILOSTAT derived data base is used
*
  set fg /
              m_tech_aspros  ,f_tech_aspros
              m_clerks       ,f_clerks
              m_service_shop ,f_service_shop
              m_off_mgr_pros ,f_off_mgr_pros
              m_ag_othlowsk  ,f_ag_othlowsk
  /;
  $$offmulti
*
* --- mapping sets from later SAM accounts to GTAP accounts
*
  set a_ag(*,ag),f_fg(*,fg),c_cg(*,cg),tf_fg(*,fg),tf_f(*,*),afin_a(*,*),afin(*),cfin(*),cfin_cg(*,*),ffin(*),ffin_f(*,*);
*
* --- not yet domain checked sets for activities,factor,commodities,factor taxes
*
  set a1(*),f1(*),c1(*),tfa1(*);
*
* --- build account labels from GTAP names
*
  $$onEmbeddedCode Python:

      a         = []
      afin      = []
      ffin      = []
      cfin      = []
      cfin_cg   = []
      a_ag      = []
      afin_a    = []
      ffin_f    = []
      f      = []
      f_fg   = []
      c      = []
      c_cg   = []
      tf_fg   = []
      tf_f    = []
      tfa     = []

      labels = gams.get('ag')
      for s in labels:
         a_ag.append(("a-"+s+"_i",s))
         afin_a.append(("a-"+s,"a-"+s+"_i"))
         afin.append("a-"+s)
         a.append("a-"+s+"_i")

      labels = gams.get('fg')
      for s in labels:
         f_fg.append(("f-"+s+"_i",s))
         f.append("f-"+s+"_i")
         ffin.append("f-"+s)
         ffin_f.append(("f-"+s,"f-"+s+"_i"))

      labels = gams.get('cg')
      for s in labels:
         c_cg.append(("c-"+s+"_i",s))
         c.append("c-"+s+"_i")
         cfin.append("c-"+s)
         cfin_cg.append(("c-"+s,s))

      labels = gams.get('fg')
      for s in labels:
         tf_f.append(("t-"+s+"_i","f-"+s+"_i"))
         tf_fg.append(("t-"+s+"_i",s))
         tfa.append("t-"+s+"_i")

      gams.set("a1",a)
      gams.set("c1",c)
      gams.set("f1",f)
      gams.set("tfa1",tfa)
      gams.set("afin",afin)
      gams.set("ffin",ffin)

      gams.set("a_ag",a_ag)
      gams.set("afin_a",afin_a)
      gams.set("ffin_f",ffin_f)
      gams.set("f_fg",f_fg)
      gams.set("c_cg",c_cg)
      gams.set("tf_fg",tf_fg)
      gams.set("tf_f",tf_f)
      gams.set("cfin",cfin)
      gams.set("cfin_cg",cfin_cg)

  $$offEmbeddedCode a1 c1 f1 tfa1 a_ag f_fg c_cg tf_fg tf_f afin_a afin ffin_f ffin cfin cfin_cg

  $$onmulti
  set ag  / set.ag,cgds /;
  set a1  / a-macc_i /;
  set c1  / c-macc_i /;
  $$offmulti


  parameter

    tVom(ag,cg,rg)    "Make matrix"
    vfm(fg,ag,rg)     "Factor demands by firms at market prices"
    vdfm(cg,ag,rg)    "Domestic intermediate demands by firms at market prices"
    vdfa(cg,ag,rg)    "Domestic intermediate demands by firms at agent prices"
    vifm(cg,ag,rg)    "Imported intermediate demands by firms at market prices"
    vifa(cg,ag,rg)    "Imported intermediate demands by firms at agent prices"
    vdpm(cg,rg)       "Domestic demands by households at market prices"
    vdpa(cg,rg)       "Domestic demands by households at agent prices"
    vipm(cg,rg)       "Imported demands by households at market prices"
    vipa(cg,rg)       "Imported demands by households at agent prices"
    vdgm(cg,rg)       "Domestic demands by government at market prices"
    vdga(cg,rg)       "Domestic demands by government at agent prices"
    vigm(cg,rg)       "Imported demands by government at market prices"
    viga(cg,rg)       "Imported demands by government at agent prices"
    viws(cg,rg,rg)    "Imports at c.i.f. (exporter first)"
    vims(cg,rg,rg)    "Imports tariffs inclusive, only stored if different from viws"
    vxwd(cg,rg,rg)    "Exports at f.o.b. (exporter first)"
    vxmd(cg,rg,rg)    "Exports at market prices, only stored if differen from vxwd"
    evoa(fg,rg)       "Factor earnings"
    osep(ag,rg)       "Production subsidies (or taxes)"
    fbep(fg,ag,rg)    "Production subsidies"
    ftrv(fg,ag,rg)    "Production taxes"
    vdep(rg)          "Depreciation"
    vst(cg,rg)        "Margin demand"

    $$iftheni.useAEZ "%useAez%"=="on"
       p_land(rg,aez,ag)   "Land cover for acitivities"
    $$endif.useAez
   ;
*
* --- load GTAP data base vectors/matrices needed to build MANAGE type SAM
*
  execute_load "dat/%version%.gdx" tVom,vfm,vdfm,vdfa,vifm,vifa,
                                     vdpm,vdpa,vipm,vipa,vdgm,vdga,vigm,viga,
                                     viws,vims,vxwd,vxmd,evoa,osep,fbep,ftrv,vst,vdep;
  $$iftheni.useAEZ "%useAez%"=="on"
     execute_load "dat/%version%.gdx" p_land;

     vfm("land",ag,rg)  = 0;
     ftrv("land",ag,rg) = 0;
     fbep("land",ag,rg) = 0;


     evoa(aez,rg)    = sum(ag,vfm(aez,ag,rg));
     evoa("land",rg) = 0;

  $$else.useAEZ
     vfm(aez,ag,rg)  = 0;
     ftrv(aez,ag,rg) = 0;
     fbep(aez,ag,rg) = 0;
     evoa(aez,rg)    = 0;
  $$endif.useAEZ
*
* --- SAM accounts (with placeholders for gender differentiated labels, even if currently not in use)"
*
  set sac / set.a1,set.c1,set.f1,
            set.tfa1,
*
*           --- tax streams, institutions and total
*
            "t-stx_i","t-prodtax_i","t-dirtax_i","t-imp_i","t-exp_i",
            "h-hhold_i","g-govt_i","e-ent_i","i-cgds_i","i-ginv_i","debt_i","w-ww_world_i","total-i"/;
  alias(sac,sacp);

  set sac0(*),sac0_sac(*,*);
  $$onEmbeddedCode Python:

      sac0     = []
      sac0_sac = []

      labels = gams.get('sac')
      for s in labels:
           i = s.find('_i')
           if i > -1:
              sac0.append(s[:i]+"_0")
              sac0_sac.append((s[:i]+"_0",s))

      gams.set("sac0",sac0)
      gams.set("sac0_sac",sac0_sac)

  $$offEmbeddedCode sac0 sac0_sac

  alias(sac0,sac00);

  singleton set g(sac)   "Government"    / "g-govt_i" /;
  singleton set h(sac)   "Household"     / "h-hhold_i" /;
  singleton set e(sac)   "Enterprise"    / "e-ent_i" /;
  singleton set w(sac)   "Rest of world" / "w-ww_world_i" /;
  singleton set i(sac)   "Savings"       / "i-cgds_i" /;
            set a(sac)   "activities"    / set.a1 /;
            set c(sac)   "commodities"   / set.c1 /;
            set f(sac)   "factors"       / set.f1 /;

             set cap(f) "Capital accounts" / f-capital_i /;

             set l(f) "Labor accounts"
             /
              f-tech_aspros_i
              f-clerks_i
              f-service_shop_i
              f-off_mgr_pros_i
              f-ag_othlowsk_i
              f-F_skl_i,f-M_skl_i,f-F_nsk_i,f-M_nsk_i
              f-m_tech_aspros_i  ,f-f_tech_aspros_i
              f-m_clerks_i       ,f-f_clerks_i
              f-m_service_shop_i ,f-f_service_shop_i
              f-m_off_mgr_pros_i ,f-f_off_mgr_pros_i
              f-m_ag_othlowsk_i  ,f-f_ag_othlowsk_i
             /
             ;

            set tfa(sac) "Factor taxes"  / set.tfa1 /;
            set t(sac)   "Tax streams"   / set.tfa1,"t-stx_i","t-prodtax_i","t-dirtax_i","t-imp_i","t-exp_i"/;

            set regAct(reg) "Selected region(s)";

  alias(c,cp);
  alias(a,ap);
  alias(f,ff);

  set aa(sac);
  aa(a) = yes;
  aa(g) = yes;
  aa(e) = yes;
  aa(w) = yes;
  aa(i) = yes;
*
*
* --- check if we are working with a GTAP-Power Data Base
*
  $$onEmbeddedCode Python:
       import os
       labels = gams.get('c')
       os.environ["GTAPPower"] = "off"
       for s in labels:
           if s.lower() == 'c-coalbl_i':
             os.environ["GTAPPower"] = "on"
       os.environ["GTAPCE"] = "off"
       for s in labels:
           if s.lower() == 'c-cem_i':
             os.environ["GTAPCE"] = "on"
  $$offEmbeddedCode

  $$iftheni.GtapPow "%sysEnv.GTAPCE%"=="on"
     $$setglobal bridgeFile GTAP_CE
     $$setglobal baseYear 2017
  $$elseifi.GtapPow "%sysEnv.GTAPPower%"=="on"
     $$setglobal bridgeFile GTAP_POW
     $$setglobal baseYear 2017
  $$else.GtapPow
     $$setglobal bridgeFile GTAP_9
     $$setglobal baseYear 2011
  $$endif.GTAPPow


  parameter samFin(sac,sac,reg);

  $$iftheni.allRegions "%calcGblCostShares%"=="on"
*     --- don't rebalance, no bridgefile or SAM will be outputted
      ifHPD = 0;
     $$setglobal RegName
      regAct(reg) = YES ;

  $$else.allRegions
*     --- rebalance, bridgefile and SAM will be outputted
     ifHPD  = 1

     set test / "%regName%" /;

     $$onEmbeddedCode Python:
          import os
          test   = gams.get('test')
          labels = gams.get('rg')
          os.environ["foundRegact"] = 'false'
          for s in labels:
                for t in test:
                    if t == s:
                      os.environ["foundRegact"] = 'true'
     $$offEmbeddedCode
     $$ifi "%sysEnv.foundRegact%"=="false" $$abort '%regName% is not a legal GTAP region label, file: %system.fn%, line: %system.incline%'

*    --- take selected name from user input
     regAct("%regname%") = YES ;
     $$if not dexist reg%system.dirsep%%regName% $call mkdir  reg%system.dirsep%%regName%
  $$endif.allRegions

 $$ifthen.GtapPow "%sysEnv.GTAPPower%"=="on"

  set ely /
      NuclearBL
      CoalBL
      GasBL
      WindBL
      HydroBL
      OilBL
      OtherBL
      GasP
      HydroP
      OilP
      SolarP
  /;
  $$else.GTAPPow
  set ely / ely /;
  $$endif.GTAPPow

  set ener / set.ely,oil,p_c,gas,gdt
     $$ifi "%sysEnv.GTAPPower%"=="on" tnd
  /;
  set elyAG(ag) / set.ely /;
  set elyCG(cg) / set.ely /;
  set enerCG(cg) / set.ener /;
  parameter labor0(reg,*,*);
  set cohorts;parameter unPop;
  $$gdxin "dat/unPop.gdx"
     $$load cohorts<unPop.dim2 unPop
  $$gdxin

$iftheni.GDLD  "%buildGender%"=="on"


   $$iftheni.newGdld exist "%datdir%/gdld_2017_V11.gdx"
*
*     --- new version constructed from ILO_STAT is available:
*        load list of available countries

      set regAvail;
      $$GDXIN "%datdir%/gdld_2017_V11.gdx"
      $$LOAD regAvail
      $$GDXIN
*
*     --- use Python to check if selected GTAP Region is in list
*
      $$onEmbeddedCode Python:
          import os
          labels = gams.get('regAvail')
          os.environ["regFoundInNewGdld"] = "false"
          for s in labels:
              if s.lower() == "%RegName%".lower():
                 os.environ["regFoundInNewGdld"] = "true"
      $$offEmbeddedCode

   $$endif.newGdld

   set lg(fg)   /tech_aspros,off_mgr_pros,clerks,service_shop,ag_othLowSk/;

   set agAll / set.ag /;
   $$onmulti
      set agAll / oxt,chm,nmm,i_s,nfm/;
   $$offMulti

   $$iftheni.newGdld "%sysEnv.regFoundInNewGdld%"=="true"

      set gdf_lg(fg,lg) /
              (m_tech_aspros  ,f_tech_aspros  ).tech_aspros
              (m_clerks       ,f_clerks       ).clerks
              (m_service_shop ,f_service_shop ).service_shop
              (m_off_mgr_pros ,f_off_mgr_pros ).off_mgr_pros
              (m_ag_othlowsk  ,f_ag_othlowsk  ).ag_othlowsk
      /;

      set gdf(fg) /
              m_tech_aspros  ,f_tech_aspros
              m_clerks       ,f_clerks
              m_service_shop ,f_service_shop
              m_off_mgr_pros ,f_off_mgr_pros
              m_ag_othlowsk  ,f_ag_othlowsk
      /;
      alias(gdf,gdf1);

      set mgdf(gdf) /
              m_tech_aspros
              m_clerks
              m_service_shop
              m_off_mgr_pros
              m_ag_othlowsk
      /;

      set fgdf(gdf) /
              f_tech_aspros
              f_clerks
              f_service_shop
              f_off_mgr_pros
              f_ag_othlowsk
      /;



      set gender / sex_m,sex_f /;
      set gdld_items /v,x/;



      parameters p_gdldShares(rg,*,gdf)
                 p_gdld(rg,gender,lg,*,gdld_items);

      execute_load "%datdir%/gdld_2017_V11.gdx" p_gdld;
*
*     ---- map to male/gender in labels of proto-sam
*
      p_gdldShares(regAct,agAll,mgdf) = sum(gdf_lg(mgdf,lg),p_gdld(regAct,"sex_m",lg,agAll,"V"));
      p_gdldShares(regAct,agAll,fgdf) = sum(gdf_lg(fgdf,lg),p_gdld(regAct,"sex_f",lg,agAll,"V"));

      $$iftheni.GtapCE "%sysEnv.GTAPCE%"=="on"
*
         set oxtA(ag) /nmn,mio,mao,mcu,moo/;alias(oxtA,oxtA1);
         set chmA(ag) /kfr,nfr,pfr,xch,rbr,plp,pls,plr/;alias(chmA,chmA1);
         set nmmA(ag) /cem,nmx/;alias(nmmA,nmmA1);
         set i_sA(ag) /isp,iss,ris,isc/;alias(i_sA,i_sA1);
         set nfmA(ag) /app,aps,ral,cpp,cps,rcp,mpp,mps,rom,nfc/;alias(nfmA,nfmA1);

         p_gdldShares(regAct,oxtA,gdf) = p_gdldShares(regAct,"oxt",gdf);
         p_gdldShares(regAct,chmA,gdf) = p_gdldShares(regAct,"chm",gdf);
         p_gdldShares(regAct,nmmA,gdf) = p_gdldShares(regAct,"nmm",gdf);
         p_gdldShares(regAct,i_sA,gdf) = p_gdldShares(regAct,"i_s",gdf);
         p_gdldShares(regAct,nfmA,gdf) = p_gdldShares(regAct,"nfm",gdf);


         p_gdld(regAct,gender,lg,oxtA,"x") $ vfm(lg,oxtA,regAct)
           = p_gdld(regAct,gender,lg,"oxt","x") * vfm(lg,oxtA,regAct)/sum(oxtA1,vfm(lg,oxtA1,regact));

         p_gdld(regAct,gender,lg,chmA,"x") $ vfm(lg,chmA,regAct)
           = p_gdld(regAct,gender,lg,"chm","x") * vfm(lg,chmA,regAct)/sum(chmA1,vfm(lg,chmA1,regact));

         p_gdld(regAct,gender,lg,nmmA,"x") $ vfm(lg,nmmA,regAct)
           = p_gdld(regAct,gender,lg,"nmm","x") * vfm(lg,nmmA,regAct)/sum(nmmA1,vfm(lg,nmmA1,regact));

         p_gdld(regAct,gender,lg,i_sA,"x") $ vfm(lg,i_sA,regAct)
           = p_gdld(regAct,gender,lg,"i_s","x") * vfm(lg,i_sA,regAct)/sum(i_sA1,vfm(lg,i_sA1,regact));

         p_gdld(regAct,gender,lg,nfmA,"x") $ vfm(lg,nfmA,regAct)
           = p_gdld(regAct,gender,lg,"nfm","x") * vfm(lg,nfmA,regAct)/sum(nfmA1,vfm(lg,nfmA1,regact));

      $$endif.GTAPCE

      p_gdldShares(regAct,"",gdf) = sum(ag,p_gdldShares(regAct,ag,gdf));
*
*     ---- convert to shares
*
      p_gdldShares(regAct,ag,gdf) $ p_gdldShares(regAct,ag,gdf)
        = p_gdldShares(regAct,ag,gdf)/sum(gdf_lg(gdf1,lg) $ gdf_lg(gdf,lg),p_gdldShares(regAct,ag,gdf1));


      p_gdldShares(regAct,"",gdf)
        = p_gdldShares(regAct,"",gdf)/sum(gdf_lg(gdf1,lg) $ gdf_lg(gdf,lg),p_gdldShares(regAct,"",gdf1));

      p_gdldShares(regAct,ag,gdf) $ (not sum(gdf_lg(gdf1,lg) $ gdf_lg(gdf,lg),p_gdldShares(regAct,ag,gdf1)))
        = p_gdldShares(regAct,"",gdf);
*
*     --- assign to proto SAM, applying to shares to GTAP data matrices
*
      vfm(gdf,ag,regact)   = sum(gdf_lg(gdf,lg),vfm(lg,ag,regact)  *   p_gdldShares(regact,ag,gdf));
      evoa(gdf,regact)     = sum(gdf_lg(gdf,lg),evoa(lg,regact)    *   p_gdldShares(regact,"",gdf));
      fbep(gdf,ag,regact)  = sum(gdf_lg(gdf,lg),fbep(lg,ag,regact) *   p_gdldShares(regact,ag,gdf));
      ftrv(gdf,ag,regact)  = sum(gdf_lg(gdf,lg),ftrv(lg,ag,regact) *   p_gdldshares(regact,ag,gdf));

      alias(ag,ag1);
      p_gdld(regact,"sex_m",lg,ag,"x") $ (not p_gdld(regact,"sex_m",lg,ag,"x"))
        = sum((gdf_lg(mgdf,lg),ag1),vfm(mgdf,ag1,regAct)*p_gdld(regact,"sex_m","tech_aspros",ag1,"x"))
        /sum((gdf_lg(mgdf,lg),ag1),vfm(mgdf,ag1,regAct));

      p_gdld(regact,"sex_f",lg,ag,"x") $ (not p_gdld(regact,"sex_f",lg,ag,"x"))
        = sum((gdf_lg(fgdf,lg),ag1),vfm(fgdf,ag1,regAct)*p_gdld(regact,"sex_f","tech_aspros",ag1,"x"))
        /sum((gdf_lg(fgdf,lg),ag1),vfm(fgdf,ag1,regAct));
*
*     --- Store employment data in persons
*
      labor0(regAct,"f-m_tech_aspros_0",sac0)    = sum((a_ag(a,ag),sac0_sac(sac0,a)),p_gdld(regact,"sex_m","tech_aspros",ag,"x"));
      labor0(regAct,"f-f_tech_aspros_0",sac0)    = sum((a_ag(a,ag),sac0_sac(sac0,a)),p_gdld(regact,"sex_f","tech_aspros",ag,"x"));
      labor0(regAct,"f-m_clerks_0",sac0)         = sum((a_ag(a,ag),sac0_sac(sac0,a)),p_gdld(regact,"sex_m","clerks",ag,"x"));
      labor0(regAct,"f-f_clerks_0",sac0)         = sum((a_ag(a,ag),sac0_sac(sac0,a)),p_gdld(regact,"sex_f","clerks",ag,"x"));
      labor0(regAct,"f-m_service_shop_0",sac0)   = sum((a_ag(a,ag),sac0_sac(sac0,a)),p_gdld(regact,"sex_m","service_shop",ag,"x"));
      labor0(regAct,"f-f_service_shop_0",sac0)   = sum((a_ag(a,ag),sac0_sac(sac0,a)),p_gdld(regact,"sex_f","service_shop",ag,"x"));
      labor0(regAct,"f-m_off_mgr_pros_0",sac0)   = sum((a_ag(a,ag),sac0_sac(sac0,a)),p_gdld(regact,"sex_m","off_mgr_pros",ag,"x"));
      labor0(regAct,"f-f_off_mgr_pros_0",sac0)   = sum((a_ag(a,ag),sac0_sac(sac0,a)),p_gdld(regact,"sex_f","off_mgr_pros",ag,"x"));
      labor0(regAct,"f-m_ag_othlowsk_0",sac0)    = sum((a_ag(a,ag),sac0_sac(sac0,a)),p_gdld(regact,"sex_m","ag_othlowsk",ag,"x"));
      labor0(regAct,"f-f_ag_othlowsk_0",sac0)    = sum((a_ag(a,ag),sac0_sac(sac0,a)),p_gdld(regact,"sex_f","ag_othlowsk",ag,"x"));

      parameter p_testGender;
      p_testGender("vfm",lg,ag,regact)  = vfm(lg,ag,regact)  - sum(gdf_lg(gdf,lg), vfm(gdf,ag,regact));
      p_testGender("fbep",lg,ag,regact) = fbep(lg,ag,regact) - sum(gdf_lg(gdf,lg), fbep(gdf,ag,regact));
      p_testGender("ftrv",lg,ag,regact) = ftrv(lg,ag,regact) - sum(gdf_lg(gdf,lg), ftrv(gdf,ag,regact));
      p_testGender("evoa",lg,"",regact) = evoa(lg,regact)    - sum(gdf_lg(gdf,lg), evoa(gdf,regact));
      p_testGender("vfm",lg,ag,regact)  $ (abs(p_testGender("vfm",lg,ag,regact))  le 1.E-9) = 0;
      p_testGender("fbep",lg,ag,regact) $ (abs(p_testGender("fbep",lg,ag,regact)) le 1.E-9) = 0;
      p_testGender("ftrv",lg,ag,regact) $ (abs(p_testGender("ftrv",lg,ag,regact)) le 1.E-9) = 0;
      p_testGender("evoa",lg,"",regact) $ (abs(p_testGender("evoa",lg,"",regact)) le 1.E-9) = 0;

      if ( card(p_testGender),abort p_testGender;);

   $$else.newGdld

      $$onmulti
      set l(f) "Labor accounts" /
       f-F_skl_i,f-M_skl_i,f-F_nsk_i,f-M_nsk_i
      /;
      $$offmulti

      $$ifi not exist "%datdir%/gdld_2014_V10.gdx" $abort "GDLD data base is missing, use of GDLD is not possible, file: %system.fn%, line: %system.incline%."
*
*        --- aggregate labour income from GTAP
*
      set gdldItems,rGdld,aGdld;
      $$GDXIN "%datdir%/gdld_2014_V10.gdx"
         $$LOAD rGdld     < p_gdld.dim1
         $$LOAD aGdld     < p_gdld.dim2
         $$LOAD gdldItems < p_gdld.dim3
      $$GDXIN

      set lgf(fg)  /m_skl,f_skl,m_nsk,f_nsk/;

      parameter p_ff(lg,fg) /     (tech_aspros,off_mgr_pros).(m_skl,f_skl)  1
                                  (clerks,service_shop).(m_skl,f_skl)  0.5
                                  (clerks,service_shop).(m_nsk,f_nsk)  0.5
                                   ag_othLowSk.(m_nsk,f_nsk) 1
      /;

      parameter p_gdld(*,*,*);
      execute_load "%datdir%/gdld_2014_V10.gdx" p_gdld;

      set aggToTot / "F_nsk","v_F_nsk","w_F_nsk"
                     "F_skl","v_F_skl","w_F_skl"
                     "M_nsk","v_M_nsk","w_M_nsk"
                     "M_skl","v_M_skl","w_M_skl" /;


      parameter popR(*);
      popR(reg) = sum(cohorts,unPop(reg,cohorts,"2017"));


      set newGtap11(reg) / CAF,TCD,COG,COD,GNQ,GAB,COM,SDN,DZA,SWZ,IRQ,LBN,PSE,SYR,MLI,NER,HTI,UZB,TJK,AFG,SRB/
      set oldGtap10(*)    / XAC,XCF,XNF,XEC,XWS,XCB,XSU,XSC,XWF,XER,XSA/;
      set G11_10(reg,oldGtap10)/        HTI.XCB
                                        SRB.XER
                                        AFG.XSA
                                        (UZB,TJK).XSU
                                        (CAF,TCD,COG,GNQ,GAB).XCF
                                        COD.XAC
                                        (MLI,NER).XWF
                                        (COM,SDN).XEC
                                        DZA.XNF
                                        SWZ.XSC
                                        (IRQ,LBN,PSE,SYR).XWS/;

      popR(oldGtap10) = sum(G11_10(newGtap11,oldGtap10), popR(newGtap11));
      p_gdld(regact,agAll,gdldItems) $ newGtap11(regAct) = sum(G11_10(regAct,oldGtap10),p_gdld(oldGtap10,agAll,gdldItems));

      p_gdld(regact,elyAg,gdldItems) = p_gdld(regAct,"ely",gdldItems);

      p_gdld(regact,agAll,"v_F_nsk") $ newGtap11(regAct) = p_gdld(regact,agAll,"v_F_nsk")* popR(regAct)/sum(G11_10(regAct,oldGtap10),popR(oldGtap10));
      p_gdld(regact,agAll,"v_F_skl") $ newGtap11(regAct) = p_gdld(regact,agAll,"v_F_skl")* popR(regAct)/sum(G11_10(regAct,oldGtap10),popR(oldGtap10));
      p_gdld(regact,agAll,"v_M_nsk") $ newGtap11(regAct) = p_gdld(regact,agAll,"v_M_nsk")* popR(regAct)/sum(G11_10(regAct,oldGtap10),popR(oldGtap10));
      p_gdld(regact,agAll,"v_M_skl") $ newGtap11(regAct) = p_gdld(regact,agAll,"v_M_skl")* popR(regAct)/sum(G11_10(regAct,oldGtap10),popR(oldGtap10));

*
*     --- define lagAllbour demand in Mio USD from GDLD data
*
      p_gdld(regact,agAll,"F_nsk")  = p_gdld(regact,agAll,"v_F_nsk") * p_gdld(regact,agAll,"w_F_nsk");
      p_gdld(regact,agAll,"F_skl")  = p_gdld(regact,agAll,"v_F_skl") * p_gdld(regact,agAll,"w_F_skl");
      p_gdld(regact,agAll,"M_nsk")  = p_gdld(regact,agAll,"v_M_nsk") * p_gdld(regact,agAll,"w_M_nsk");
      p_gdld(regact,agAll,"M_skl")  = p_gdld(regact,agAll,"v_M_skl") * p_gdld(regact,agAll,"w_M_skl");


      $$iftheni.GtapCE "%sysEnv.GTAPCE%"=="on"
*
         set oxtA /nmn,mio,mao,mcu,moo/;
         set chmA /kfr,nfr,pfr,xch,rbr,plp,pls,plr,c_plt/;
         set nmmA /cem,nmx/;
         set i_sA /i_s isp,iss,ris,isc/;
         set nfmA /app,aps,ral,cpp,cps,rcp,mpp,mps,rom,nfc/;

         p_gdld(regAct,oxtA,aggToTot) = p_gdld(regAct,"oxt",aggToTot);
         p_gdld(regAct,chmA,aggToTot) = p_gdld(regAct,"chm",aggToTot);
         p_gdld(regAct,nmmA,aggToTot) = p_gdld(regAct,"nmm",aggToTot);
         p_gdld(regAct,i_sA,aggToTot) = p_gdld(regAct,"i_s",aggToTot);
         p_gdld(regAct,nfmA,aggToTot) = p_gdld(regAct,"nfm",aggToTot);

      $$endif.GTAPCE
*
*     --- agggregate to economy total
*
      p_gdld(regact,"",aggToTot)   = sum(ag,p_gdld(regact,ag,aggToTot));

      p_gdld(regact,"","w_F_nsk")  = p_gdld(regact,"","F_nsk") / p_gdld(regact,"","v_F_nsk");
      p_gdld(regact,"","w_F_skl")  = p_gdld(regact,"","F_skl") / p_gdld(regact,"","v_F_skl");
      p_gdld(regact,"","w_M_nsk")  = p_gdld(regact,"","M_nsk") / p_gdld(regact,"","v_M_nsk");
      p_gdld(regact,"","w_M_skl")  = p_gdld(regact,"","M_skl") / p_gdld(regact,"","v_M_skl");

      p_gdld(regact,ag,"w_F_nsk") $ (not p_gdld(regact,ag,"w_F_nsk")) = p_gdld(regact,"","w_F_nsk");
      p_gdld(regact,ag,"w_F_skl") $ (not p_gdld(regact,ag,"w_F_skl")) = p_gdld(regact,"","w_F_skl");
      p_gdld(regact,ag,"w_M_nsk") $ (not p_gdld(regact,ag,"w_M_nsk")) = p_gdld(regact,"","w_M_nsk");
      p_gdld(regact,ag,"w_M_skl") $ (not p_gdld(regact,ag,"w_M_skl")) = p_gdld(regact,"","w_M_skl");
*
*     --- agggregate to skilled / unskilled, for activities and total
*
      p_gdld(regact,ag,"nsk") = p_gdld(regact,ag,"F_nsk") + p_gdld(regact,ag,"M_nsk");
      p_gdld(regact,ag,"skl") = p_gdld(regact,ag,"F_skl") + p_gdld(regact,ag,"M_skl");
*
      p_gdld(regact,"","nsk") = sum(ag,p_gdld(regact,ag,"F_nsk") + p_gdld(regact,ag,"M_nsk"));
      p_gdld(regact,"","skl") = sum(ag,p_gdld(regact,ag,"F_skl") + p_gdld(regact,ag,"M_skl"));;
*
*     --- convert in shares on total skilled / unksilled
*
      p_gdld(regact,ag,"F_nsk") $ p_gdld(regact,ag,"F_nsk")  = p_gdld(regact,ag,"F_nsk")/p_gdld(regact,ag,"nsk");
      p_gdld(regact,ag,"F_skl") $ p_gdld(regact,ag,"F_skl")  = p_gdld(regact,ag,"F_skl")/p_gdld(regact,ag,"skl");
      p_gdld(regact,ag,"M_nsk") $ p_gdld(regact,ag,"M_nsk")  = p_gdld(regact,ag,"M_nsk")/p_gdld(regact,ag,"nsk");
      p_gdld(regact,ag,"M_skl") $ p_gdld(regact,ag,"M_skl")  = p_gdld(regact,ag,"M_skl")/p_gdld(regact,ag,"skl");
*
      p_gdld(regact,"","F_nsk") $ p_gdld(regact,"","F_nsk")  = p_gdld(regact,"","F_nsk")/p_gdld(regact,"","nsk");
      p_gdld(regact,"","F_skl") $ p_gdld(regact,"","F_skl")  = p_gdld(regact,"","F_skl")/p_gdld(regact,"","skl");
      p_gdld(regact,"","M_nsk") $ p_gdld(regact,"","M_nsk")  = p_gdld(regact,"","M_nsk")/p_gdld(regact,"","nsk");
      p_gdld(regact,"","M_skl") $ p_gdld(regact,"","M_skl")  = p_gdld(regact,"","M_skl")/p_gdld(regact,"","skl");

      alias(fg,fg1);
      p_gdld(regact,ag,fg) $ (not sum(fg1,p_gdld(regact,ag,fg1)))  = p_gdld(regact,"",fg);

      set wages / w_F_nsk
                  w_F_skl
                  w_M_nsk
                  w_M_skl
      /;
      p_gdld(regact,ag,wages) $ (not p_gdld(regact,ag,wages))  = p_gdld(regact,"",wages);

*
*     --- correct double agccounting provoked by agssigning skilled / unSkilled to both cagtegories in agggregation statements above
*         by multiplicagtion of male/female shagres
*
      vfm(lgf,ag,regact)   = sum(lg,vfm(lg,ag,regact)  *  p_ff(lg,lgf) * p_gdld(regact,ag,lgf));
      evoa(lgf,regact)     = sum(lg,evoa(lg,regact)    *  p_ff(lg,lgf) * p_gdld(regact,"",lgf));
      fbep(lgf,ag,regact)  = sum(lg,fbep(lg,ag,regact) *  p_ff(lg,lgf) * p_gdld(regact,ag,lgf));
      ftrv(lgf,ag,regact)  = sum(lg,ftrv(lg,ag,regact) *  p_ff(lg,lgf) * p_gdld(regact,ag,lgf));

      labor0(regAct,"f-f_nsk_0",sac0) $ sum((a_ag(a,ag),sac0_sac(sac0,a)),p_gdld(regact,ag,"w_F_nsk"))
        = sum((a_ag(a,ag),sac0_sac(sac0,a)),vfm("f_nsk",ag,regact)/p_gdld(regact,ag,"w_F_nsk"))*1000;
      labor0(regAct,"f-m_nsk_0",sac0) $ sum((a_ag(a,ag),sac0_sac(sac0,a)),p_gdld(regact,ag,"w_M_nsk"))
        = sum((a_ag(a,ag),sac0_sac(sac0,a)),vfm("m_nsk",ag,regact)/p_gdld(regact,ag,"w_M_nsk"))*1000;
      labor0(regAct,"f-f_skl_0",sac0) $ sum((a_ag(a,ag),sac0_sac(sac0,a)),p_gdld(regact,ag,"w_F_skl"))
        = sum((a_ag(a,ag),sac0_sac(sac0,a)),vfm("f_skl",ag,regact)/p_gdld(regact,ag,"w_F_skl"))*1000;
      labor0(regAct,"f-m_skl_0",sac0) $ sum((a_ag(a,ag),sac0_sac(sac0,a)),p_gdld(regact,ag,"w_M_skl"))
        = sum((a_ag(a,ag),sac0_sac(sac0,a)),vfm("m_skl",ag,regact)/p_gdld(regact,ag,"w_M_skl"))*1000;

   $$endif.newGdld



   vfm(lg,ag,regact)   = 0;
   evoa(lg,regact)     = 0;
   fbep(lg,ag,regact)  = 0;
   ftrv(lg,ag,regact)  = 0;

$endif.GDLD

* -------------------------------------------------------------------------------
*
*   Build SAM(s)
*
* -------------------------------------------------------------------------------

  $$batinclude "inc/title.inc" '" %regName%: Define initial SAM from GTAP global sam"'
*
* (1) Make matrix
*
  samFin(a,c,regAct) = sum((a_ag(a,ag),c_cg(c,cg)),tVom(ag,cg,regAct));
  samFin(a,c,regAct) $ (samFin(a,c,regAct) le 1.E-9) = 0;
*
* --- don't keep activities producing less than 1E-x * MioUsd
*
  set aact(a,*); aact(a,regAct) $ (sum(c,samFin(a,c,regAct)) gt %minProdValue%) = yes;
  samFin(a,c,regAct)  $ (not aact(a,regAct)) = 0;
*
* (2) Factor demands net of factor taxes
*
  samFin(f,aact(a,regAct)) = sum((f_fg(f,fg),a_ag(a,ag)),vfm(fg,ag,regAct));
  samFin(f,a,regAct) $ (samFin(f,a,regAct) le 1.E-9) = 0;
*
* --- ensure some minimal capital use in absolute and relative use, required for vintages
*

  samFin(f,aact(a,regAct)) $ (samFin(f,a,regAct) $ (not sameas(f,"f-capital_i"))
                                            $   (   (samFin("f-capital_i",a,regAct) le 1.E-7)
                                                 or (samFin("f-capital_i",a,regAct) le 5.E-4*sum(c,samFin(a,c,regact)))
                                                 or (samFin("f-capital_i",a,regAct) le 1.E-2*sum(ff,samFin(ff,a,regAct)))))
        = samFin(f,a,regAct)*0.99;

  samFin("f-capital_i",a,regAct) $ (sum(f,samFin(f,a,regAct)) $ (    (samFin("f-capital_i",a,regAct) le 1.E-7)
                                                 or (samFin("f-capital_i",a,regAct) le 5.E-4*sum(c,samFin(a,c,regact)))
                                                                   or (samFin("f-capital_i",a,regAct) le 1.E-2*sum(f,samFin(f,a,regAct)))))
        = Max(1.E-7,5.E-4*sum(c,samFin(a,c,regact)),1.E-2 * sum(f,samFin(f,a,regAct)))*1.01;
*
* (3) Intermediate input use tax inclusive
*
  samFin(c,aact(a,regAct)) = sum((c_cg(c,cg),a_ag(a,ag)),vdfa(cg,ag,regAct) + vifa(cg,ag,regAct));
  samFin(c,aact(a,regAct)) $ (samFin(c,a,regAct) lt 1.E-%minCostShare%*sum(cp,samFin(cp,a,regAct))) = 0;
  samFin(c,aact(a,regAct)) $ (samFin(c,a,regAct) le 1.E-9) = 0;
*
* (4) Commodity use by household, by household, by savings, all tax inclusive
*
  samFin(c,h,regAct)  = sum(c_cg(c,cg),vdpa(cg,regAct)        + vipa(cg,regAct));
  samFin(c,h,regAct) $ (samFin(c,h,regAct) lt 1.E-%minCostShare%*sum(cp,samFin(cp,h,regAct))) = 0;
  samFin(c,g,regAct)  = sum(c_cg(c,cg),vdga(cg,regAct)        + viga(cg,regAct));
  samFin(c,g,regAct) $ (samFin(c,g,regAct) lt 1.E-%minCostShare%*sum(cp,samFin(cp,g,regAct))) = 0;
  samFin(c,i,regAct)  = sum(c_cg(c,cg),vdfa(cg,"cgds",regAct) + vifa(cg,"cgds",regAct));
  samFin(c,i,regAct) $ (samFin(c,i,regAct) lt 1.E-%minCostShare%*sum(cp,samFin(cp,i,regAct))) = 0;
*
* (5) sales taxes by product: difference between demand at agent and market prices
*
  samFin("t-stx_i",c,regAct) =      samFin(c,h,regAct)
                                  + samFin(c,g,regAct)
                                  + samFin(c,i,regAct)
                                  + sum(a,samFin(c,a,regAct))

                             -  sum(c_cg(c,cg),  vdpm(cg,regAct)           + vipm(cg,regAct)
                                               + vdgm(cg,regAct)           + vigm(cg,regAct)
                                               + sum(ag,vdfm(cg,ag,regAct) + vifm(cg,ag,regAct)));

  samFin(g,"t-stx_i",regact) = sum(c,samFin("t-stx_i",c,regAct));
*
* (6) Imports at c.i.f. + tariffs
*
  samFin(w,c,regAct) = sum((c_cg(c,cg),rg),viws(cg,rg,regAct));
*
* (7) Exports at f.o.b., plus demand for international transport margins
*
  samFin(c,w,regAct) = sum((c_cg(c,cg)),sum(rg,vxwd(cg,regAct,rg)) + vst(cg,regAct));
  samFin(c,w,regAct) $ (not sum(a, samFin(a,c,regAct))) = 0;
*
* (9) factor earnings by households and direct taxation
*
  samFin(h,f,regAct) = sum(a,samFin(f,a,regAct));
*
* --- direct taxes by factor: differene between factor renumeration paid by firms
*     and revenues received (evoa)

  samFin("t-dirtax_i",h,regAct) = sum(f, samFin(h,f,regAct)) -  sum(f_fg(f,fg),evoa(fg,regAct));
  samFin(g,"t-dirtax_i",regAct) = samFin("t-dirtax_i",h,regAct);
*
* (10) production taxes
*
  samFin("t-prodtax_i",aact(a,regAct))  = sum(a_ag(a,ag),-osep(ag,regact));
  samFin(g,"t-prodtax_i",regact)        = sum(ag,-osep(ag,regact));
*
* (11) factor taxes and subsidies
*
  samFin(tfa,aact(a,regAct)) = sum((tf_fg(tfa,fg),a_ag(a,ag)),ftrv(fg,ag,regact)+fbep(fg,ag,regact));

  samFin(g,tfa,regact) = sum(a,samFin(tfa,a,regAct));
*
* (12) import taxes (beware: vims is zero if identical to viws)
*
  samFin("t-imp_i",c,regAct) = sum((c_cg(c,cg),rg) $ vims(cg,rg,regAct),vims(cg,rg,regAct)-viws(cg,rg,regAct));
  samFin(g,"t-imp_i",regact) = sum(c,samFin("t-imp_i",c,regAct));
*
* (14) export taxes (beware: vxmd is zero if identical to vxwd)
*
  samFin("t-exp_i",c,regAct) $ sum((c_cg(c,cg),rg) $ vxmd(cg,regAct,rg),vxwd(cg,regAct,rg))
   = sum((c_cg(c,cg),rg) $ vxmd(cg,regAct,rg),vxwd(cg,regAct,rg) - vxmd(cg,regAct,rg));
  samFin("t-exp_i",c,regAct) $ (not sum(a, samFin(a,c,regAct))) = 0;
  samFin(g,"t-exp_i",regact) = sum(c,samFin("t-exp_i",c,regAct));
*
* --- move 50% of hhld capital earnings to enterprise account and treat as transfers to enterprises to hhld
*     enterprises are supposed to finance depreciation, transfers to households are corrected accordingly
*
  samFin(e,"f-Capital_i",regAct) = samFin(h,"f-Capital_i",regAct) * 0.5;
  samFin(h,"f-Capital_i",regAct) = samFin(h,"f-Capital_i",regAct) * 0.5;
  samFin(h,e,regAct)             = samFin(e,"f-Capital_i",regAct) - vdep(regAct);
*
* -----------------------------------------------------------------------------
*
*   Split part of cattle for meat and cattle for milk into a separate
*   raising activity
*
* -----------------------------------------------------------------------------
*
  $$iftheni.ctlRais "%ctlRais%"=="on"
*
*     -- production value of new activity is use of milk and cattle production
*        in milk and cattle production
*
      samFin("a-ctlRais_i","c-ctlRais_i",regAct)
           =   samFin("c-ctl_i","a-ctl_i",regAct) + samFin("c-rmk_i","a-ctl_i",regAct)
             + samFin("c-ctl_i","a-rmk_i",regAct) + samFin("c-rmk_i","a-rmk_i",regAct);
*
*     --- asssign production costs to new activity according to
*         share of the own-input use
*
      samFin(sac,"a-ctlRais_i",regAct)
        = samFin(sac,"a-ctl_i",regAct) * [(samFin("c-ctl_i","a-ctl_i",regAct) + samFin("c-rmk_i","a-ctl_i",regAct))
                                         /sum(sacp,samFin(sacp,"a-ctl_i",regAct))] $ sum(sacp,samFin(sacp,"a-ctl_i",regAct))
        + samFin(sac,"a-rmk_i",regAct) * [(samFin("c-ctl_i","a-rmk_i",regAct) + samFin("c-rmk_i","a-rmk_i",regAct))
                                         /sum(sacp,samFin(sacp,"a-rmk_i",regAct))] $ sum(sacp,samFin(sacp,"a-rmk_i",regAct))   ;
*
*     --- replace these intermediate input uses in cattle meat and cattle milk
*         production by use of the new input
*
      samFin("c-ctlRais_i","a-ctl_i",regAct) $ samFin("a-ctlRais_i","c-ctlRais_i",regAct)
        = samFin("c-ctl_i","a-ctl_i",regAct)     + samFin("c-rmk_i","a-ctl_i",regAct);

      samFin("c-ctlRais_i","a-rmk_i",regAct) $ samFin("a-ctlRais_i","c-ctlRais_i",regAct)
        = samFin("c-ctl_i","a-rmk_i",regAct)     + samFin("c-rmk_i","a-rmk_i",regAct);

      samFin("c-ctlRais_i","a-ctlRais_i",regAct) $ samFin("a-ctlRais_i","c-ctlRais_i",regAct)
        = samFin("c-ctl_i","a-ctlRais_i",regAct) + samFin("c-rmk_i","a-ctlRais_i",regAct);
*
*     --- and delete the old intermediate input use

      samFin("c-ctl_i","a-rmk_i",regAct)     = 0;
      samFin("c-rmk_i","a-rmk_i",regAct)     = 0;
      samFin("c-ctl_i","a-ctl_i",regAct)     = 0;
      samFin("c-rmk_i","a-ctl_i",regAct)     = 0;
      samFin("c-ctl_i","a-ctlRais_i",regAct) = 0;
      samFin("c-rmk_i","a-ctlRais_i",regAct) = 0;
*
*     --- reduce production costs of cattle and milk production accordingly
*
      samFin(sac,"a-ctl_i",regAct)
        = samFin(sac,"a-ctl_i",regAct) * (1- samFin("c-ctlRais_i","a-ctl_i",regAct)
                                            /sum(sacp,samFin(sacp,"a-ctl_i",regAct)));

      samFin(sac,"a-rmk_i",regAct)
        = samFin(sac,"a-rmk_i",regAct) * (1- samFin("c-ctlRais_i","a-rmk_i",regAct)
                                            /sum(sacp,samFin(sacp,"a-rmk_i",regAct)));
*
*     --- reduce output of the two activities accordingly
*
      samFin("a-rmk_i","c-rmk_i",regAct)         = sum(sac, samFin(sac,"a-rmk_i",regAct));
      samFin("a-ctl_i","c-ctl_i",regAct)         = sum(sac, samFin(sac,"a-ctl_i",regAct));

      $$iftheni.labor0 defined labor0
       labor0(regAct,sac0,"a-ctlRais_0") $ (labor0(regAct,sac0,"a-ctl_0") and sum(sac0_sac(sac0,l),samFin(l,"a-ctl_i",regAct)))
          = labor0(regAct,sac0,"a-ctl_0")*sum(sac0_sac(sac0,l), samFin(l,"a-ctlRais_i",regAct)/samFin(l,"a-ctl_i",regAct));
      $$endif.labor0

      aact("a-ctlRais_i",regAct) = yes;
  $$endif.ctlRais
*
* -----------------------------------------------------------------------------
*
*   Add care economy account
*
* -----------------------------------------------------------------------------
*
  $$iftheni.careEcon "%careEcon%"=="on"

    set lFem(f) "Female Labor accounts"  /
      f-f_nsk_i,f-f_skl_i
      f-f_tech_aspros_i
      f-f_clerks_i
      f-f_service_shop_i
      f-f_off_mgr_pros_i
      f-f_ag_othlowsk_i
     /;


    set lFem0 "Female Labor accounts"  /
      f-f_nsk_0,f-f_skl_0
      f-f_tech_aspros_0
      f-f_clerks_0
      f-f_service_shop_0
      f-f_off_mgr_pros_0
      f-f_ag_othlowsk_0
     /;
    set lMal0 "Female Labor accounts"  /
      f-m_nsk_0,f-m_skl_0
      f-m_tech_aspros_0
      f-m_clerks_0
      f-m_service_shop_0
      f-m_off_mgr_pros_0
      f-m_ag_othlowsk_0
     /;

*
*   --- load unpop by sex
*
    set sex /m,f/;
    set cohort /p1564/,popYears / %baseYear% /;
    parameter p_pop(reg,cohort,sex,popYears);
    execute_load "dat/unPopHist.gdx" p_pop;
*
*   --- determine make and labor participation rates
*
    parameter p_work(reg,sex,*);
    p_work(regact,"m","totLab")   = sum((lMal0,sac0),labor0(regAct,lMal0,sac0));
    p_work(regact,"f","totLab")   = sum((lFem0,sac0),labor0(regAct,lFem0,sac0));
    p_work(regact,sex,"pop")      = p_pop(regAct,"p1564",sex,"%baseYear%");
    p_work(regact,sex,"labPart")  = p_work(regact,sex,"totLab")/p_work(regact,sex,"pop");
    p_work(regact,"f","labPart*") = max(p_work(regact,"m","labPart"),p_work(regact,"f","labPart")*1.1);
    display p_work;
*
*   --- account is assumed to use female labor, only, use 50% of ammount reported in SAM
*
    labor0(regact,lFem0,"a-care_0") = sum(sac0,labor0(regAct,lFem0,sac0)) * (p_work(regact,"f","labPart*")-p_work(regact,"f","labPart"))/p_work(regact,"f","labPart");
    samFin(lFem,"a-care_i",regAct)  = sum(a,   samFin(lFem,a,regAct))     * (p_work(regact,"f","labPart*")-p_work(regact,"f","labPart"))/p_work(regact,"f","labPart");
*
*   --- output value equal of new activity is equal to (shadow) wages received
*
    samFin("a-care_i","c-care_i",regAct) = sum(lFem,samFin(lFem,"a-care_i",regAct));
*
*   --- output is consumed by household
*
    samFin("c-care_i",h,regAct) =  samFin("a-care_i","c-care_i",regAct);
*
*   --- add additional labor income to household account
*
    samFin(h,lFem,regAct) =  sum(a, samFin(lFem,a,regAct));

  $$endif.careEcon

* -----------------------------------------------------------------------------
*
*   Add electric transport
*
* -----------------------------------------------------------------------------

  $$iftheni.otpEle "%otpEle%"=="on"
*
*    --- define SAM entries for electrified otehr transport
*
*        --- (1) first, split up sam into the two products
*

      parameter p_otpEleShare(*);

      set cEly(c);
      cEly(c) $ sum(c_cg(c,elyCG),1) = YES;
      $$ifi  "%sysEnv.GTAPPower%"=="on" cEly("c-tnd_i") = YES;

      set cEner(c);
      cEner(c) $ sum(c_cg(c,enerCG),1) = YES;

      p_otpEleShare(regAct) $ samFin("a-otp_i","c-otp_i",regAct)
         = max(1.E-6,sum(cely,samFin(cEly,"a-otp_i",regAct))/sum(cEner,samFin(cEner,"a-otp_i",regAct)));
      cEner(cEly) = No;

      samFin("a-otpEle_i","c-otpEle_i",regAct)    = samFin("a-otp_i","c-otp_i",regAct) * p_otpEleShare(regAct);
      samFin(sac,"a-otpEle_i",regAct)             = samFin(sac,"a-otp_i",regAct)       * p_otpEleShare(regAct);

      samFin("a-otp_i","c-otp_i",regAct) = samFin("a-otp_i","c-otp_i",regAct) * (1-p_otpEleShare(regAct));
      samFin(sac,"a-otp_i",regAct)       = samFin(sac,"a-otp_i",regAct)       * (1-p_otpEleShare(regAct));

      samFin("c-otpEle_i",sac,regAct)    = samFin("c-otp_i",sac,regAct) * samFin("a-otpEle_i","c-otpEle_i",regAct)
                                           /(sum(sacp,samFin(sacp,"c-otp_i",regAct))+samFin("a-otpEle_i","c-otpEle_i",regAct));

      samFin("c-otp_i",sac,regAct)      = samFin("c-otp_i",sac,regAct) * (1-samFin("a-otpEle_i","c-otpEle_i",regAct)
                                           /(sum(sacp,samFin(sacp,"c-otp_i",regAct))+samFin("a-otpEle_i","c-otpEle_i",regAct)));
*
*        --- (2) rebook costs of electricity from standard to electrified
*
      samFin(cEly,"a-otpEle_i",regAct) = samFin(cEly,"a-otpEle_i",regAct) + samFin(cEly,"a-otp_i",regAct);
      samFin(cEly,"a-otp_i",regAct)    = 0;
*
*        --- (3) rebook costs of fossils from electrified to standard
*
      samFin(cEner,"a-otp_i",regAct)    = samFin(cEner,"a-otpEle_i",regAct) + samFin(cEner,"a-otp_i",regAct);
      samFin(cEner,"a-otpEle_i",regAct) = 0;
*
*        --- (4) close account with capital costs
*
      samFin("f-capital_i","a-otp_i",regAct)
        = max(samFin("f-capital_i","a-otp_i",regAct)*0.5,
              samFin("f-capital_i","a-otp_i",regAct)    + samFin("a-otp_i","c-otp_i",regAct)       - sum(sac,samFin(sac,"a-otp_i",regact)));

      samFin("f-capital_i","a-otpEle_i",regAct)
        = max(samFin("f-capital_i","a-otpEle_i",regAct)*0.5,
              samFin("f-capital_i","a-otpEle_i",regAct) + samFin("a-otpEle_i","c-otpEle_i",regAct) - sum(sac,samFin(sac,"a-otpEle_i",regact)));

      $$iftheni.labor0 defined labor0
       labor0(regAct,sac0,"a-otpEle_0") $ (labor0(regAct,sac0,"a-otp_0") and sum(sac0_sac(sac0,l),samFin(l,"a-otp_i",regAct)))
          = labor0(regAct,sac0,"a-otp_0")*sum(sac0_sac(sac0,l), samFin(l,"a-otpEle_i",regAct)/samFin(l,"a-otp_i",regAct));
      $$endif.labor0

      aact("a-otpEle_i",regAct) = yes;
  $$endif.otpEle

* -----------------------------------------------------------------------------
*
*   Add MACC account
*
* -----------------------------------------------------------------------------
*
  samFin("a-macc_i","c-macc_i",regAct) = min(1,5.E-8*sum((a,c),samFin(a,c,regAct)));
*
  samFin("c-macc_i",aact(a,regact)) $ (not sameas(a,"a-macc_i")) = sum(c,samFin(a,c,regAct));
  samFin("c-macc_i",aact(a,regact)) = samFin("c-macc_i",a,regact)
    * samFin("a-macc_i","c-macc_i",regAct)/sum(ap,samFin("c-macc_i",ap,regact));


  parameter p_maccShare(c) / c-obs_i    0.15
                             c-ofi_i    0.03
                             c-cmn_i    0.03
                          $$ifthen.GtapPow "%sysEnv.GTAPPower%"=="on"
                             c-edu_i    0.15
                             c-gasp_i   0.05
                             c-oilp_i   0.03
                             c-coalBL_i 0.02
                             c-ins_i    0.01
                             c-eeq_i    0.05
                          $$else.GtapPow
                             c-ros_i    0.15
                             c-ely_i    0.10
                             c-isr_i    0.01
                             c-ele_i    0.05
                          $$endif.GtapPow
                             c-cns_i    0.12
                             c-lum_i    0.01
                             c-ome_i    0.21
                             c-trd_i    0.03
    /;

  p_maccShare(c) = p_maccShare(c)/sum(cp, p_maccShare(cp));

  set lab(f);
  lab(f) $ sum((a,regAct),samFin(f,a,regAct)) = yes;
  lab("f-land_i")    = no;
  lab("f-capital_i") = no;
  lab("f-natlres_i") = no;
  lab("f-water_i")   = no;
  lab(f) $ sum(f_fg(f,aez),1) = no;

  samFin("f-capital_i","a-macc_i",regAct) = samFin("a-macc_i","c-macc_i",regAct) * 0.1;
  samFin(lab,"a-macc_i",regAct)           = samFin("a-macc_i","c-macc_i",regAct) * 0.1/card(lab);
  samFin(c,"a-macc_i",regAct)             = samFin("a-macc_i","c-macc_i",regAct) * 0.8 * p_maccShare(c);

* -----------------------------------------------------------------------------
*
*   Add water account
*
* -----------------------------------------------------------------------------

  $$iftheni.waterSplit "%waterSplit%"=="on"

      parameter p_splitShares(reg,fg,a);
      execute_load "dat/splitSharesWater.gdx" p_splitShares;

      set lnd(f),tLnd(tfa);
      lnd(f) $ f_fg(f,"land")    = YES;
      lnd(f) $ sum(f_fg(f,aez),1) = YES;

      tLnd(tfa) $ tf_fg(tfa,"land")     = YES;
      tLnd(tfa) $ sum(tf_fg(tfa,aez),1) = YES;

      samFin("f-water_i",a,regAct) $ p_splitShares(regAct,"water",a) = sum(lnd,samFin(lnd,a,regAct))   * p_splitShares(regAct,"water",a);
      samFin("t-water_i",a,regAct) $ p_splitShares(regAct,"water",a) = sum(tlnd,samFin(tlnd,a,regAct)) * p_splitShares(regAct,"water",a);
      samFin(lnd,a,regAct)         $ p_splitShares(regAct,"water",a) = samFin(lnd,a,regAct)            * (1-p_splitShares(regAct,"water",a));
      samFin(tlnd,a,regAct)        $ p_splitShares(regAct,"water",a) = samFin(tlnd,a,regAct)           * (1-p_splitShares(regAct,"water",a));

      parameter p_waterShare(reg,*);
      p_waterShare(regAct,"F") = sum(a,samFin("f-water_i",a,regAct))/sum(a,samFin("f-water_i",a,regAct) + sum(lnd,samFin(lnd,a,regAct)));
      p_waterShare(regAct,"T") $ sum(a,samFin("t-water_i",a,regAct) + sum(tlnd,samFin(tlnd,a,regAct)))
       = sum(a,samFin("t-water_i",a,regAct))/sum(a,samFin("t-water_i",a,regAct) + sum(tlnd,samFin(tlnd,a,regAct)));

      samFin("f-water_i",sac,regAct) $ (not a(sac)) = sum(lnd,samFin(lnd,sac,regAct))*p_waterShare(regAct,"F");
      samFin("t-water_i",sac,regAct) $ (not a(sac)) = sum(tlnd,samFin(tlnd,sac,regAct))*p_waterShare(regAct,"T");
      samFin(lnd,sac,regAct)         $ (not a(sac)) = samFin(lnd,sac,regAct) *(1-p_waterShare(regAct,"F"));
      samFin(tlnd,sac,regAct)        $ (not a(sac)) = samFin(tlnd,sac,regAct)*(1-p_waterShare(regAct,"T"));

      samFin(sac,"f-water_i",regAct) $ (not a(sac)) = sum(lnd,samFin(sac,lnd,regAct))*p_waterShare(regAct,"F");
      samFin(sac,"t-water_i",regAct) $ (not a(sac)) = sum(tlnd,samFin(sac,tlnd,regAct))*p_waterShare(regAct,"T");
      samFin(sac,lnd,regAct)         $ (not a(sac)) = samFin(sac,lnd,regAct) *(1-p_waterShare(regAct,"F"));
      samFin(sac,tlnd,regAct)        $ (not a(sac)) = samFin(sac,tlnd,regAct)*(1-p_waterShare(regAct,"T"));

  $$endif.waterSplit

  $$iftheni.labor0 defined labor0

      labor0(regAct,sac0,"a-macc_0") $ ((not labor0(regAct,sac0,"a-macc_0")) $ sum((sac0_sac(sac0,lab),a),samFin(lab,a,regAct)))
         = sum(sac0_sac(sac00,a),labor0(regAct,sac0,sac00))*sum(sac0_sac(sac0,lab), samFin(lab,"a-macc_i",regAct))
         /sum((sac0_sac(sac0,lab),a),samFin(lab,a,regAct));

  $$endif.labor0

*
* --- Load data on foreign debt and introduce flows into SAM
*
  parameter debtData(reg,*,*);
  set debtPos,debtYears;

  $$onUnDf
  $$GDXIN 'dat/debtData.gdx'
    $$LOAD debtData
    $$LOAD debtPos<debtData.dim2
    $$LOAD debtYears<debtData.dim3
  $$GDXIN
  $$offUnDf
*
* --- delete data for regions which are not processed by current run
*
  debtData(reg,debtPos,debtYears)       $ (not regAct(reg)) = 0;
*
* --- convert to millions
*
  debtData(reg,debtPos,debtYears) = debtData(reg,DebtPos,debtYears)*1.E-6;
*
* --- special options
*
  $$ifthene.lowDebt %debtStckD%*%newDebtToGovConsumption%=0
*
*    --- debt stock to gov consumption is set to zero on interface,
*        also the given data on international debt are deleted
*
     debtData(regAct,"debtStkd","2017")       = 0;
     debtData(regAct,"debtStk","2017")        = 0;
     debtData(regAct,"debtPrinciple","2017")  = 0;
     debtData(regAct,"debtInt","2017")        = 0;
     debtData(regAct,"newDebt","2017")        = 0;

  $$elseife.lowDebt %debtStckD%*%newDebtToGovConsumption%=0.001*0.001
*
*    --- both new debt and the old debt stock are reduced to a tiny number
*
     $$setglobal debtCorr 1.E-6

     debtData(regAct,"debtStk","2017")        = sum((c,g),samFin(c,g,regAct))      * %debtCorr%;
     debtData(regAct,"debtPrinciple","2017")  = debtData(regAct,"debtStk","2017")  * %debtPrinciple%/100;
     debtData(regAct,"debtInt","2017")        = debtData(regAct,"debtStk","2017")  * 0.02;
     debtData(regAct,"newDebt","2017")        = sum((c,g),samFin(c,g,regAct))      * %debtCorr%;

     $$setglobal debtStckD               %debtCorr%
     $$setglobal newDebtToGovConsumption %debtCorr%
  $$endif.lowDebt

*
* --- invent debt stock of x% of gov consumption and charge y% interest plus z% repayments
*     invent a new debt of x% of gov consumption. This is steered by the options from the interface
*
  debtData(regAct,"debtStkD","2017")       = sum((c,g),samFin(c,g,regAct))      * %debtStckD% + eps;
  debtData(regAct,"debtIntD","2017")       = debtData(regAct,"debtStkd","2017") * %debtIntd%/100;
  debtData(regAct,"debtPrincipleD","2017") = debtData(regAct,"debtStkd","2017") * %debtPrinciple%/100;
  debtData(regAct,"newDebtD","2017")       = sum((c,g),samFin(c,g,regAct))      * %newDebtToGovConsumption% + eps;

  $$ifthene.fullRepayment %debtPrinciple%>98
*
*    --- redefine debt stock based on observed debt principle (debt stock lasts for around one year, only)
*
     debtData(regAct,"debtStk","2017")        = debtData(regAct,"debtPrinciple","2017")/%debtPrinciple%*100;
     debtData(regAct,"debtPrinciple","2017")  = debtData(regAct,"debtStk","2017")*%debtPrinciple%/100;
     debtData(regAct,"newDebt","2017")        = debtData(regAct,"debtPrinciple","2017")+debtData(regAct,"debtInt","2017");
  $$endif.fullRepayment
*
* --- book invented transaction into SAM
*
  samFin(g,"debt_i",regAct)    = debtData(regAct,"newDebtD","2017");
  samFin("debt_i",g,regAct)    = debtData(regAct,"DebtPrincipleD","2017") + debtData(regAct,"DebtIntD","2017");
  samFin("debt_i",h,regAct)    = debtData(regAct,"newDebtD","2017");
  samFin(h,"debt_i",regAct)    = debtData(regAct,"DebtPrincipleD","2017") + debtData(regAct,"DebtIntD","2017");
  samFin(h,g,regAct)           = samFin(h,g,regAct)
                                 + samFin(g,"debt_i",regAct) - debtData(regAct,"DebtPrincipleD","2017") - debtData(regAct,"DebtIntD","2017");
*
* --- new foreign debt by government, add to debt income; principal and interest as expenditures
*
  debtData(regAct,"debtPrinciple","2017") = max(0.01*debtData(regAct,"debtStk","2017"),debtData(regAct,"debtPrinciple","2017"));
  debtData(regAct,"debtPrinciple","2017") = max(0.01*debtData(regAct,"debtStk","2017"),debtData(regAct,"debtPrinciple","2017"));

  debtData(regAct,"debtPrinciple","2017") $ (not debtData(regAct,"debtPrinciple","2017")) = 0.05;
  $$ife %debtStckD%*%newDebtToGovConsumption%=0 debtData(regAct,"debtPrinciple","2017")   = 0;

  samFin(g,"debt_i",regAct)  = samFin(g,"debt_i",regAct) + max(0,debtData(regAct,"newDebt","2017"));
  samFin("debt_i",g,regAct)  = samFin("debt_i",g,regAct) + debtData(regAct,"DebtPrinciple","2017")
                                                         + debtData(regAct,"DebtInt","2017")
                                                         + min(0,debtData(regAct,"newDebt","2017"));
*
* --- foreign payments on debt: principal and interest as revenue, new debt as expenditures
*
  samFin(w,"debt_i",regAct)  =  debtData(regAct,"DebtPrinciple","2017")
                              + debtData(regAct,"DebtInt","2017")
                              + min(0,debtData(regAct,"newDebt","2017"));
  samFin("debt_i",w,regAct)  =  max(0,debtData(regAct,"newDebt","2017"));
*
* --- book exchanges with RoW as a transfer between Gov and Row to keep the SAM balanced
*
  parameter netDebtFlow;

  netDebtFlow(regAct) = debtData(regAct,"newDebt","2017") - debtData(regAct,"DebtPrinciple","2017") - debtData(regAct,"DebtInt","2017");
*
  samFin(w,g,regAct) $ (netDebtFlow(regAct) gt 0) =  netDebtFlow(regAct);
  samFin(g,w,regAct) $ (netDebtFlow(regAct) lt 0) = -netDebtFlow(regAct);
*
* (15) close institutional accounts with savings
*
  samFin(i,e,regact) = sum(sac,samFin(e,sac,regact)-samFin(sac,e,regact));
  samFin(i,g,regact) = sum(sac,samFin(g,sac,regact)-samFin(sac,g,regact));
  samFin(i,h,regact) = sum(sac,samFin(h,sac,regact)-samFin(sac,h,regact));
  samFin(i,w,regAct) = sum(c, samFin(w,c,regAct)-samFin(c,w,regAct));
*
* --- move positive gov savings to households transfers
*
  samFin(i,h,regact) $ (samFin(i,g,regact) gt 0) = samFin(i,h,regact) + samFin(i,g,regact);
  samFin(h,g,regact) $ (samFin(i,g,regact) gt 0) = samFin(h,g,regact) + samFin(i,g,regact);
  samFin(i,g,regact) $ (samFin(i,g,regact) gt 0) = 0;
*
* --- rebook part of foreign savings in household savings and define matching transfer from ROW to household
*     if households savings are negative
*
  parameter oriSav;

  oriSav(regAct,w)    = samFin(i,w,regAct);
  oriSav(regAct,"h")  = samFin(i,h,regAct);

  display oriSav;


  samFin(i,h,regAct) $ ( (oriSav(regAct,"h") lt 0) and (oriSav(regAct,w) gt 0))
    = samFin(i,h,regAct) + min(abs(oriSav(regAct,"h")),oriSav(regAct,w)*0.9) + sum(sac,samFin(sac,g,regact))*0.05;

  samFin(i,w,regAct)  $ ( (oriSav(regAct,"h") lt 0) and (oriSav(regAct,w) gt 0))
   = samFin(i,w,regAct) - min(abs(oriSav(regAct,"h")),oriSav(regAct,w)*0.9) + sum(sac,samFin(sac,g,regact))*0.05;

  samFin(h,w,regAct)  $ ( (oriSav(regAct,"h") lt 0) and (oriSav(regAct,w) gt 0))
   = samFin(h,w,regAct) + min(abs(oriSav(regAct,"h")),oriSav(regAct,w)*0.9) + sum(sac,samFin(sac,g,regact))*0.05;



  oriSav(regAct,w)    = samFin(i,w,regAct);
  oriSav(regAct,"h")  = samFin(i,h,regAct);
*
* --- construct distribution of factor income by activity and institution
*
  set inst  / "h-hhold","g-govt","w-ww_world","e-ent"/;
  set inst_sac(inst,sac) /"h-hhold"."h-hhold_i","g-govt"."g-govt_i","w-ww_world"."w-ww_world_i","e-ent"."e-ent_i"/;
  samFin(w,l,regAct)   = samFin(h,l,regAct)   * %shareForeignLab%/100;
  samFin(w,cap,regAct) = samFin(h,cap,regAct) * %shareForeignCap%/100;
  samFin(h,f,regAct)   = samFin(h,f,regAct)        - samFin(w,f,regAct);
  samFin(h,w,regAct)   = sum(f,samFin(w,f,regAct)) + samFin(h,w,regAct);
*
* ----------------------------------------------------------------------------
*
*   On demand: use user supplied correction to final SAM
*
* ----------------------------------------------------------------------------

  $$iftheni.samCorr "%useSamCorrFile%"=="on"

      $$include 'reg%system.dirsep%%regName%%system.dirsep%%samCorrFile%.inc'

  $$endif.samCorr


* -----------------------------------------------------------------------------
*
*    HDP balancing rountine to remove small infeasibilities
*
* -----------------------------------------------------------------------------

  variable
   v_rowsum                      "Sum of estimates for each row"
   v_colsum                      "Sum of estimates for each column"
   v_samfin(sac,sac,reg)         "Balanced SAM entry estimates"
   v_bot                         "B.O.T"
   v_obj                         "Squared relative difference"
  ;

  equation
   rowsumeq                      "Sum of estimates for each row"
   colsumeq                      "Sum of estimates for each column"
   constEq                       "Column equal row sum constraint"
   exportEq                      "Output needs to exceed exports"
   exportTEq                     "Exports need to exceed export tax"
   tFacEq                        "Factor taxes cannot exceed factor cost"
   minCapEq                      "Minimum share of capital cost of output"
   botEq
   bopEq
   objEq                         "Objective definition"
  ;

  singleton set curReg(reg) "Current region in balancing problem";

  rowsumeq(sac,reg) $ curReg(reg) ..

    v_rowsum(sac,reg) =e= sum(sacp $ samfin(sacp,sac,reg),v_samfin(sacp,sac,reg)) ;

  colsumeq(sac,reg) $ curReg(reg) ..

    v_colsum(sac,reg) =e= sum(sacp $ samfin(sac,sacp,reg),v_samfin(sac,sacp,reg)) ;

  constEq(sac,reg)  $ curReg(reg) ..

    v_rowsum(sac,reg) =e= v_colsum(sac,reg) ;


   botEq(reg) $ curReg(reg) ..

     v_bot(reg) =E=   sum((c,w) $ samfin(c,w,reg), v_samFin(c,w,reg))
                    - sum((w,c) $ samfin(w,c,reg), v_samFin(w,c,reg));

   bopEq(reg) $ curReg(reg) ..

     v_bot(reg) =E= -sum((sac,w) $ (samfin(sac,w,reg) and (not c(sac))), v_samFin(sac,w,reg))
                    +sum((w,sac) $ (samfin(w,sac,reg) and (not c(sac))), v_samFin(w,sac,reg));

  exportEq(c,reg)  $ (curReg(reg)  $ samFin(c,w,reg)) ..

    v_samFin(c,w,reg) =L= sum(a $ samFin(a,c,reg), v_samFin(a,c,reg))*0.99 - 1.E-6 + v_samFin("t-exp_i",c,reg) $ samFin("t-exp_i",c,reg);

  exporttEq(c,reg)  $ (curReg(reg)  $ samFin(c,w,reg)) ..

    v_samFin(c,w,reg) =G= (v_samFin("t-exp_i",c,reg)*0.1 + 1.E-6) $ samFin("t-exp_i",c,reg);

  tFacEq(f,a,reg)  $ (curReg(reg)  $ samFin(f,a,reg)) ..
    sum(tf_f(tfa,f) $ samFin(tfa,a,reg),v_samFin(tfa,a,reg)) + 1.E-6  =G= -v_samFin(f,a,reg)*0.75;

  minCapEq(a,reg)  $ (curReg(reg) $ samFin("f-capital_i",a,reg))  ..
      v_samFin("f-capital_i",a,reg) =G= 0.0005*sum(c $ samFin(c,a,reg),v_samFin(a,c,reg))+1.E-6;

  objEq..

    v_obj  * sum((sac,sacp,reg) $ (samfin(sac,sacp,reg) $ curReg(reg)),1)
                              =e= sum((sac,sacp,reg) $ (samfin(sac,sacp,reg) $ curReg(reg)),
                                        sqr((v_samfin(sac,sacp,reg)-samfin(sac,sacp,reg))/(samfin(sac,sacp,reg)+1e-6)));
  model hpd /all/ ;
  hpd.holdfixed = 1 ;

  Parameter
   samfinDiff  "Differences between pre and post balancing SAM"
  ;

  if(ifhpd,

*
*     --- define regions for which the estimator will run
*
      option kill=regact;
      $$iftheni.regest "%regName%"==""
        regAct(reg) = YES ;
      $$else.regest
        regAct("%regname%") = YES ;
      $$endif.regest
      loop(regAct,

         $$batinclude "inc/title.inc" '" %regName%: HPD balancing for region "' regAct.tl
         curReg(regAct) = YES;
*
*        --- set start value for SAM cells, colum and row sums and prevent introducing new non-zeros
*
         v_samfin.l(sacp,sac,curReg) = samfin(sacp,sac,curReg) ;
         v_samfin.lo(sacp,sac,curReg)    $ (samfin(sacp,sac,curReg) gt 0) =  1.E-6;
         v_samfin.up(sacp,sac,curReg)    $ (samfin(sacp,sac,curReg) lt 0) = -1.E-6;

         v_samfin.lo(c,aa,curReg) $  samfin(c,aa,curReg)  = 1.E-6;
         v_samfin.lo(a,c,curReg)  $  samfin(a,c,curReg)   = 1.E-6;
         v_samfin.lo(w,c,curReg)  $  samfin(w,c,curReg)   = 1.E-6;
         v_samfin.lo(f,a,curReg)  $  samfin(f,a,curReg)   = 1.E-6;

         v_samfin.fx(sacP,sac,reg) $ (NOT samfin(sacp,sac,reg)) = 0;

         v_rowsum.l(sac,reg) = sum(sacp,samfin(sacp,sac,reg));
         v_colsum.l(sac,reg) = sum(sacp,samfin(sac,sacp,reg));

         v_rowsum.fx(sac,reg) $ (NOT v_rowsum.l(sac,reg)) = 0;
         v_colsum.fx(sac,reg) $ (NOT v_colsum.l(sac,reg)) = 0;

         v_bot.l(reg) =     sum((c,w) $ samfin(c,w,reg), v_samFin.l(c,w,reg))
                          - sum((w,c) $ samfin(w,c,reg), v_samFin.l(w,c,reg));
*
*        --- define start value for objective value
*
         v_obj.l = sum((sac,sacp,reg) $ (samfin(sac,sacp,reg) $ curReg(reg)),
                                        sqr((v_samfin.l(sac,sacp,reg)-samfin(sac,sacp,reg))/(samfin(sac,sacp,reg)+1e-6)))
                                / sum((sac,sacp,reg) $ (samfin(sac,sacp,reg) $ curReg(reg)),1);
*
*        --- each tenth solve, cleanse memory by a solvelink 0
*
         hpd.solveLink= 5;
         option QCP=%QCPSolver%;
         $$ifi "%QCPSolver%"=="CONOPT4" hpd.optfile = 4;
         if ( mod(regAct.pos,10) eq 0,hpd.solvelink=0);
         solve hpd minimizing v_obj using QCP ;
         if ( (hpd.solvestat eq 4) or (hpd.modelStat eq 4),
            option QCP=Conopt4;
            hpd.optfile = 5;
            solve hpd minimizing v_obj using QCP ;
         );
*
*        --- report differences and assign post-balancing results to SAM
*
         samfinDiff(sacp,sac,regAct) = v_samfin.l(sacp,sac,regAct)-samfin(sacp,sac,regAct);
         samfin(sacp,sac,regAct)     = v_samfin.l(sacp,sac,regAct) ;
         samfinDiff(sacp,sac,regAct) $(abs(samfinDiff(sacp,sac,regAct)) lt 1E-6)= 0 ;

         option kill=v_samFin,kill=v_rowSum,kill=v_colSum,kill=rowSumEq,kill=colSumEq,kill=constEq;
      );

      $$iftheni "%calcGblCostShares%"=="on"
        regAct(reg) = YES ;
      $$endif
  );


*-------------------------------------------------------------------------------
*
* Construct MACRO SAM
*
*-------------------------------------------------------------------------------

  $$batinclude "inc/title.inc" '" %regName%: Construct macro SAM "'

  SET acm /
     a-macro     "Sum of all activities accounts"
     c-macro     "Sum of all product accounts"
     l-macro     "Labor account"
     cap-macro   "Capital account"
     lnd-macro   "Land and natural ressources account"
     h-macro     "Household account"
     e-macro     "Enterprise account"
     g-macro     "Government account"
     i-macro     "Investment/savings account"
     debt-macro  "Debt account"
     w-macro     "Rest-of-the-world account"
     tprod-macro "Production taxes account"
     tdir-macro  "Direct taxes account"
     tstx-macro  "Sales tax account"
     timp-macro  "Import tax account"
     texp-macro  "Export tax account"
     tFac-macro  "Factor tax account"
*    --- Attention: total3 is fixed name used in SAMEST, do not change
     total3      "Sum over accounts"
  /;

  set acm_sac(acm,sac) "Match aggregate macro accounts to detailed SAM account"
  /
    a-macro.set.a
    c-macro.set.c
    l-macro.set.l
    h-macro.set.h
    e-macro.e-ent_i
    g-macro.set.g
    debt-macro.debt_i
    i-macro.set.i
    i-macro.i-ginv_i
    w-macro.set.w
    cap-macro.f-Capital_i
    lnd-macro.f-NatlRes_i
    lnd-macro.f-land_i
    lnd-macro.f-aez1_i
    lnd-macro.f-aez2_i
    lnd-macro.f-aez3_i
    lnd-macro.f-aez4_i
    lnd-macro.f-aez5_i
    lnd-macro.f-aez6_i
    lnd-macro.f-aez7_i
    lnd-macro.f-aez8_i
    lnd-macro.f-aez9_i
    lnd-macro.f-aez10_i
    lnd-macro.f-aez11_i
    lnd-macro.f-aez12_i
    lnd-macro.f-aez13_i
    lnd-macro.f-aez14_i
    lnd-macro.f-aez15_i
    lnd-macro.f-aez16_i
    lnd-macro.f-aez17_i
    lnd-macro.f-aez18_i
    lnd-macro.f-water_i
    tFac-macro.(set.tfa)
    tExp-macro.t-exp_i
    timp-macro.t-imp_i
    tProd-macro.t-PRODTAX_i
    tdir-macro.t-DIRTAX_i
    tstx-macro.t-stx_i
    total3.total-i
  /;

  alias(acm,acmp) ;

  set testAcm(*);
  testAcm(acm) $ (not sum(acm_sac(acm,sac),1)) = YES;
  if ( card(testAcm), abort "Some macro-sam accounts are not mapped to any proto-sam accounts, file: %system.fn%, line: %system.incline%",testAcm);
  testAcm(sac) $ (not sum(acm_sac(acm,sac),1)) = YES;
  if ( card(testAcm), abort "Some proto-sam accounts are not mapped to any proto-sam accounts, file: %system.fn%, line: %system.incline%",testAcm);
*
* ---- generate macro SAM
*
  Parameter p_macroSamAll(acm,acmp,reg);

   p_macroSamAll(acm,acmp,reg)     = sum((sac,sacp) $ (acm_sac(acm,sac) and acm_sac(acmp,sacp)),samFin(sac,sacp,reg)) ;

*-------------------------------------------------------------------------------
*
* Calculate global average cost shares in production (on demand)
* This can be useful to add, for instance, new activities into a SAM
* such as renewable
*
*-------------------------------------------------------------------------------

 Parameter avgCostShare(sac,a);
 $$iftheni "%calcGblCostShares%"=="on"

    $$batinclude "inc/title.inc" '" %regName%: Calculate average global cost shares for all activities "'

*   --- calculate average cost structure for all products

    avgCostShare(sac,a) = sum(reg,samfin(sac,a,reg)) / sum((sacp,reg),samfin(a,sacp,reg)) ;
 $$else
    option kill=avgCostShare;
 $$endif

*-------------------------------------------------------------------------------
*
*  Update EXCEL sheets (solely if working for one GTAP region)
*
*-------------------------------------------------------------------------------

 $$onEcho > '%gams.scrdir%/howToRead.txt'
    par=defPar rng=defPar!B2   rDim=1
    par=actPar rng=actPar!A1   rDim=1    cDim=2
    par=mapKNestShr rng=mapk!B5   rDim=1 cDim=1
    set=mapaAgr     rng=Maps!R6   rDim=2
 $$offecho

 $$call 'gdxxrw.exe input="dat/Bridgefile_%bridgeFile%_template.xlsx" output="%gams.scrdir%fromTemplate.gdx" @%gams.scrdir%/howToRead.txt'
*
*--- read default parameters from GDX and add country specific data
*
 parameter defPar(*),actPar(*,*,*);
 $$GDXIN %gams.scrdir%fromTemplate.gdx
    $$LOAD defPar
    $$LOAD actPar
 $$GDXIN

 $$iftheni.regname not "%regName%"==""

      parameter p_macroSam(acm,acmp);
      p_macroSam(acm,acmp) = p_macroSamAll(acm,acmp,"%regName%")
*
*     --- copy templates for SAM and bridgefile in EXCEL from dat directory to regional one
*
      $$iftheni.GTAPPow "%sysEnv.GTAPCE%"=="on"
         $$call cp "dat%system.dirsep%SAM_GTAP_POW_template.xlsx" "reg%system.dirsep%%regName%%system.dirsep%SAM_%regName%_GTAP.xlsx"
         $$call cp "dat%system.dirsep%Bridgefile_GTAP_CE_template.xlsx" "reg%system.dirsep%%regName%%system.dirsep%BaseBridge_%regName%_GTAP_CE.xlsx"
      $$elseifi.GtapPow "%sysEnv.GTAPPower%"=="on"
         $$call cp "dat%system.dirsep%SAM_GTAP_POW_template.xlsx" "reg%system.dirsep%%regName%%system.dirsep%SAM_%regName%_GTAP.xlsx"
         $$call cp "dat%system.dirsep%Bridgefile_GTAP_POW_template.xlsx" "reg%system.dirsep%%regName%%system.dirsep%BaseBridge_%regName%_GTAP_POW.xlsx"
      $$else.GTAPPow
         $$call cp "dat%system.dirsep%SAM_GTAP_STD_template.xlsx" "reg%system.dirsep%%regName%%system.dirsep%SAM_%regName%_GTAP.xlsx"
         $$call cp "dat%system.dirsep%Bridgefile_GTAP_9_template.xlsx" "reg%system.dirsep%%regName%%system.dirsep%BaseBridge_%regName%_GTAP_9.xlsx"
      $$endif.GTAPPow

      $$batinclude "inc/title.inc" '" %regName%: Add proto and MACRO SAM "'
*
*     --- read in macro totals and set GDP from MACRO SAM
*
      $$batinclude "inc/title.inc" '" %regName%: Update MACRO totals"'
      $$call 'gdxxrw.exe input="reg/%regName%/SAM_%regName%_GTAP.xlsx" par=Macro rng=macro!A6   rDim=1       output="%gams.scrdir%macro.gdx"'

      parameter macro(*);
      $$GDXIN %gams.scrdir%macro.gdx
         $$LOAD macro
      $$GDXIN
*
*     --- define GDP at market prices from expenditure side
*
      macro("tgdpmp2") =   sum( (c,i), samFin(c,i,"%regName%"))
                         + sum( (c,g), samFin(c,g,"%regName%"))
                         + sum( (c,h), samFin(c,h,"%regName%"))
                         + sum( (c,w), samFin(c,w,"%regName%"))
                         - sum( (w,c), samFin(w,c,"%regName%"));
*
*     --- define GDP at market prices from revenue side
*
      macro("tgdpmp3") =   sum( (f,a), samFin(f,a,"%regName%"))
                         + sum( (t,a), samFin(t,a,"%regName%"))
                         + sum( (t,c), samFin(t,c,"%regName%"))
                         + sum( (g,a), samFin(g,a,"%regName%"))
                         + sum( (g,c), samFin(g,c,"%regName%"));
*
*     --- check for differences, afterward, delete tgdpmp3 position, otherwise, SAMEST will fail
*
      if ( abs(macro("tgdpmp2") - macro("tgdpmp3")) gt 0.1, abort "Some error in definition of GDP from revenue and expenditure side, file: %system.fn%, line: %system.incline%");
      macro("tgdpmp3") = 0;
*
*     --- read in default parameters, demand and agggregate sector mapping from EXCEL to GDX
*
      $$batinclude "inc/title.inc" '" %regName%: Add information on foreign debt"'
*
*     --- add physical production from FAOSTAT
*
      parameter p_GTAPProd(rg,aFin);
      execute_load 'dat/faoProd.gdx' p_gtapProd;
      actPar(afin,"physProd","") = p_gtapProd("%regName%",aFin)*1.E-3;
*
*     --- this is default assumption in GTAP to which the depreciation fits
*
      defPar("depr0") = 0.04;

      alias(afin,afin1);
      actPar(afin,"depr","") = actPar(afin,"depr","") *  defPar("depr0") * sum(afin_a(afin1,a),samFin("f-capital_i",a,"%regName%"))
                                                                          / sum(afin_a(afin1,a),samFin("f-capital_i",a,"%regName%")*actPar(aFin1,"depr",""));
*
*     --- calculate capital stock backward and from there the capital stock to GDP ratio
*
      defPar("capoutRate0") =  [vdep("%regName%")/0.04]/macro("tgdpmp2");
*
*     --- assign debt data
*
      defPar("DebtStkD0") = debtData("%regName%","debtStkd","2017");
      defPar("DebtIntD0") = 1.E-6;
      defPar("DebtIntD0") $ (debtData("%regName%","debtStkD","2017") gt eps) = debtData("%regName%","debtIntD","2017")/debtData("%regName%","debtStkD","2017") * 100;
      defPar("DebtStkF0") = debtData("%regName%","debtStk","2017") + eps;
      $$ife %debtStckD%*%newDebtToGovConsumption%=0 defPar("DebtStkF0") = eps;
      defPar("DebtIntF0") = 1.E-6;
      defPar("DebtIntF0") $ (debtData("%regName%","debtStk","2017") gt eps) = debtData("%regName%","debtInt","2017")/debtData("%regName%","debtStk","2017") * 100;
*
*     --- calculate debt to GDP and store in default par (currently not used in model code)
*
      defPar("debtGdpTgt0") =  (defPar("DebtStkD0") + defPar("DebtStkF0"))/macro("tgdpmp2");
      defPar("GDP")         =  macro("tgdpmp2");
*
*     -- read in GDP projections from MFMOD and put into dynamics sheet
*
      $$batinclude "inc/title.inc" '" %regName%: Add information on porjected GDP changes from MFMOD"'
      parameter mfmodGdp(*,reg);
      $$GDXIN 'dat/mfmodGdp.gdx'
        $$LOAD mfmodGdp
      $$GDXIN
      set projYears / %baseYear%*2100 /;
      alias(projYears,projYears1);

      parameter dynamics(*,*);

      $$batinclude "inc/title.inc" '" %regName%: Add proto and MACRO SAM "'

      parameter p_protoSam(sac,sacp);
      p_protoSam(sac,sacp) = samFin(sac,sacp,"%regName%");
      p_protoSam(sac,sac) $ (not sum(sacp,samFin(sac,sacp,"%regName%")))    = 1.E-20;
      p_protoSam("debt_i",h)         $ (not p_protoSam("debt_i",h))         = 1.E-20;
      p_protoSam("debt_i","e-ent_i") $ (not p_protoSam("debt_i","e-ent_i")) = 1.E-20;

   $$endif.regname
*
*  --- GTAP V11 CDE demand system parameters for all regions and products
*
   table subp(*,*) "Substitution parameters"
                     AUS            NZL            XOC            CHN            HKG            JPN            KOR            MNG            TWN            BRN            KHM            IDN            LAO            MYS            PHL            SGP            THA            VNM            XEA            XSE            AFG            BGD            IND            NPL            PAK            LKA            XSA            CAN            USA            MEX            XNA            ARG            BOL            BRA            CHL            COL            ECU            PRY            PER            URY            VEN            XSM            CRI            GTM            HND            NIC            PAN            SLV            XCA            DOM            JAM            HTI            PRI            TTO            XCB            AUT            BEL            BGR            HRV            CYP            CZE            DNK            EST            FIN            FRA            DEU            GRC            HUN            IRL            ITA            LVA            LTU            LUX            MLT            NLD            POL            PRT            ROU            SVK            SVN            ESP            SWE            GBR            NOR            CHE            XEF            ALB            SRB            BLR            RUS            UKR            XEE            XER            KAZ            KGZ            TJK            UZB            XSU            ARM            AZE            GEO            BHR            IRN            IRQ            ISR            JOR            KWT            LBN            OMN            PSE            QAT            SAU            SYR            TUR            ARE            XWS            DZA            EGY            MAR            TUN            XNF            BEN            BFA            CMR            CIV            GHA            GIN            MLI            NER            NGA            SEN            TGO           