********************************************************************************
$ontext

   MANAGE project

   GAMS file : opt.inc

   @purpose  : Define core options of model, folders to use, time
   @author   : Hasan Dudu and MTI team, W. Britz for GUI integration
   @date     : 18.11.22
   @since    :
   @refDoc   :
   @seeAlso  :
   @calledBy : run.gms

$offtext
********************************************************************************
  $$setEnv GDXCOMPRESS 1


  $$if "%scrdir%"==""       $dropglobal scrdir
  $$ifthen.scrdir not setglobal scrdir

     $$onEmbeddedCode Python:
       import os

       scrdir = r'%gams.scrdir%\'[:-2]
       os.environ["scrdir"] = scrdir

       gams.printLog(scrdir)


     $$offEmbeddedCode

     $$setglobal scrdir %sysenv.scrdir%

  $$endif.scrdir
*
* --- include file generated by GUI with run specific settings
*
  $$ifi not setglobal iScen $setglobal iScen
  $$ifi not setglobal simName        $setglobal simName
  $$ifi not setglobal simNamePostFix $setglobal simNamePostFix
  $$setglobal simNameOri %simName%
  $$setglobal regGtapNameOri %regGtapName%

  $$setglobal baseDir .
  $$if setglobal curDir $setglobal baseDir %curDir%
  $$setGlobal oDir     "%baseDir%%system.dirsep%res%system.dirsep%%RegGtapName%"
  $$setGlobal datF     "%baseDir%%system.dirsep%dat"
  $$setGlobal savF     "%baseDir%%system.dirsep%sav"
  $$setGlobal simF     "%baseDir%%system.dirsep%reg%system.dirsep%%RegGtapName%%system.dirsep%sim"
  $$setGlobal regF     "%baseDir%%system.dirsep%reg%system.dirsep%%RegGtapName%"
*
* --- if we are working on clone direcotry, use the first chars to get the GTAP region
*
  $$onembeddedCode Python:
     import os
     os.environ["regGtapName"] = "%regGtapName%"[0:3]
  $$offembeddedCode
  $$setglobal regGtapName %sysEnv.regGtapName%

  $$iftheni.task "%task%"=="baseline"

     $$iftheni.BG "%BGCheck%"=="on"
        $$setglobal shk_File balGrowth
     $$endif.BG
*
*    --- if the user has not left the simName field empty, append
*        the suggested name after BAU
*
     $$iftheni.emptyName not "%simname%"==""
        $$setglobal SimName BaU_%simname%
     $$else.emptyName
        $$setglobal SimName BaU
     $$endif.emptyName

  $$else.task

     $$setglobal taskType simulation
*
*    --- if not simulation name is given by user, use name of shock file
*
     $$iftheni.simFileType "%ShockFileType%"=="GAMS"
        $$setglobal simName %shk_file%
     $$else.simFileType
        $$setglobal simName %shk_file_xslx%
     $$endif.simFileType

  $$endif.task

  $$setglobal simNameFile %simName%
  $$ifi not "%simNameOri%"=="" $setglobal simName %simNameOri%
*
* --- store both the shock file used and given variant
*
  $$setglobal outSimName %simNameFile%
  $$ifi not "%SimNameOri%"=="" $setglobal outSimName %simNameFile%_%simname%
  $$ifi not setglobal SimNamePostFix $$setglobal SimNamePostFix

  $$ifi not "%iScen%"==""      $setglobal outSimName %outSimName%_%iScen%

  $$setGlobal pgmName  %task%
*
* --- control over stochastics
*
  $$ifi "%task%"=="Stochastic simulation" $setglobal draws on
  $$ifi "%task%"=="Sensitivity analysis"  $setglobal draws on

  $$iftheni.task not "%draws%"=="on"
    $$setglobal nDraws
  $$endif.task

  set dummy0/0/;


  $$ifthen.stoch not "%iScen%"==""
*
*    --- a child run for a specific stochastic experiment
*
     $$iftheni.stochSim "%task%"=="Stochastic simulation"
       $$setglobal stochastics on
       $$setglobal stochRun on
     $$endif.stochSim
     set draws /%iScen% /;
     $$setglobal draws ,"%iScen%"
     $$setglobal ddraws ,*

  $$elseifi.stoch not "%nDraws%"==""

     $$setglobal draws ,draws
     $$setglobal ddraws ,*
     $$setglobal stochastics on
     $$iftheni.task "%task%"=="Stochastic simulation"
         set draws /base,d1*d%nDraws%/;
     $$else.task
        $$eval nDraws    round(%nDraws%)
        $$eval lastDraw  %nDraws% + (%startDraws%-1)*%nDraws%
        $$eval firstDraw (%startDraws%-1)*%nDraws%+1
        set draws        / base,d%firstDraw%*d%LastDraw%/;
     $$endif.task

  $$else.stoch

     $$setglobal draws
     $$setglobal ddraws
     $$setglobal stochastics off
     set draws /""/;

  $$endif.stoch
*
* --- generate output directories is not existing
*
  $$iftheni.stoch "%iScen%"==""
     $$ifi not dexist .%system.dirsep%html                             $call mkdir .%system.dirsep%htlm
     $$ifi not dexist .%system.dirsep%sav                              $call mkdir .%system.dirsep%sav
     $$ifi not dexist .%system.dirsep%res                              $call mkdir .%system.dirsep%res
     $$ifi not dexist .%system.dirsep%res%system.dirsep%%RegGtapName%  $call mkdir .%system.dirsep%res%system.dirsep%%RegGtapName%
     $$ifi not dexist .%system.dirsep%gui%system.dirsep%xml            $call mkdir .%system.dirsep%gui%system.dirsep%xml
  $$endif.stoch

  $$iftheni.investLink "%investLink%"=="on"

     $$ifi not set investmodulesCropproduction  $set investmodulesCropproduction  OFF
     $$ifi not set investmodulesCroppollination $set investmodulesCroppollination OFF
     $$ifi not set investmodulesErosion         $set investmodulesErosion         OFF

     $$ifi "%investfeedbacksCropProduction%_%investmodulesCropproduction%"  =="ON_OFF" $$abort "Feed back link Crop production  requires the invest module Crop production being switched on"
     $$ifi "%investfeedbacksCroppollination%_%investmodulesCropPollination" =="ON_OFF" $$abort "Feed back link Crop pollination requires the invest module Crop pollination being switched on"
     $$ifi "%investfeedbacksErosion%_%investmodulesErosion%"                =="ON_OFF" $$abort "Feed back link Erosion          requires the invest module Erosion being switched on"

     $$onmulti
         $$ifi "%investfeedbacksCropProduction%"=="ON"  set chnl / cropProd /;
         $$ifi "%investfeedbacksCropPollination%"=="ON" set chnl / cropPollination /;
         $$ifi "%investfeedbacksErosion%"=="ON"         set chnl / erosion  /;
     $$onmulti

     file csvInvest / "%scrDir%/toInvest.csv" /;
     parameter p_investShocks(*,*);
     option kill=p_investShocks;
     set dummyInvest /cropProd,erosion,cropPollination/;
  $$else.investLink
     $$setglobal investFeedBacks
     $$setglobal investModules
  $$endif.investLink

*
* --- model steering flags
*
  scalars
     ifDelSt              "Data base comprises stock changes"                         / 0 /
     ifVintUpdate         "Update parameters of old nest"                             / 1 /
     ifDmg                "Set to 1 to activate Climate change damages"               / 0 /
     ifVint               "Set to 1 for capital vintages"                             / 1 /
     ifLabVint            "Set to 1 for labor vintages"                               / 1 /
     ifCal                "Activate baseline calibration"                             / 0 /
     ifAirPollDmg         "Activate air pollution impact on labor productivity"       / 0 /
     ifFiscalResp         "Gov over GDP share decreases above x% debt to GDP"         / 0 /
     ifBenchMarkCheck     "Solve model at t0 values"                                  / 0 /
     ifForwardLooking     "Forward looking"                                           / 0 /
     futureYears          "Number of future years considers"                          / 0 /
     p_expWgt             "Linear weight decrease for future years"                   / 0 /
     ifLandProdAsLabor    "Land productivity follows labor productivity"              / 0 /
     ifNatResProdAsLabor  "Natural resource productivity follows labor productivity"  / 0 /
     ifCapProdAsLabor     "Capital productivity follows labor productivity"           / 0 /
     ifLabProdDiff        "Labor productivity in broad sectors depends on GDP growth" / 0 /
     ifSectSpecInv        "Sector specific investments"                               / 0 /
     ifRowTransfersPop    "Row transfers are driven by pop=1 or GPD=0"                / 1 /
     ifChicFacCap         "Capital income share following savings"                    / 0 /
     isShortRun           "Used for unexpected shocks in productivities"              / 0 /
     ifEnTech             "Endogenous technological change"                           / 0 /
    ifFixPgdpmp                                                          / 0 /;
  ;

  $$ifi not setglobal shortRunShock $setglobal shortRunShock off
  $$iftheni.shortRunShock "%shortRunShock%"=="off"
     set shockMode /''/;
  $$else.shortRunShock
     set shockMode /'','shortRun'/;
  $$endif.shortRunShock

  $$iftheni.baseline "%task%"=="Baseline"

   $$ife %LandProdAsLabor%>0                                       ifLandProdAsLabor   = 1;
   $$ife %NatResProdAsLabor%>0                                     ifNatResProdAsLabor = 1;
   $$ife %capProdAsLabor%>0                                        ifCapProdAsLabor    = 1;
   $$ifi "%DiffLabProd%"=="on"                                     ifLabProdDiff       = 1;
   $$ifi "%sectSpecInv%"=="on"                                     ifSectSpecInv       = 1;
   $$ifi "%chicFacCap%"=="on"                                      ifchicFacCap        = 1;
   $$ifi not "%rowTransferDriver%"=="Driven by population growth" ifRowTransfersPop=0;

  $$else.baseline

    $$setglobal LandProdAsLabor   0
    $$setglobal capProdAsLabor    0
    $$setglobal NatResProdAsLabor 0
    $$setglobal diffLabProd       off
    ifLabProdDiff                 = 0;
    ifLandProdAsLabor             = 0;
    ifNatResProdAsLabor           = 0;
  $$endif.baseline

  $$ifi "%vintages%"=="off" $setglobal endoTech off
  $$ifi "%endoTech%"=="on"  ifEnTech            = 1;
  $$ifi "%endoTech%"=="off" ifEnTech            = 0;

  $$ifi "%benchmarkCheck%"=="on" ifBenchMarkCheck  = 1;
  $$ifi not setglobal ForwardLooking $setglobal ForwardLooking off
  $$ifi not setglobal considerCarbon $setglobal considerCarbon off

  $$iftheni.forwardLooking "%forwardLooking%"=="on"
       ifForWardlooking  = 1;
       futureYears       = %futureYears%;
       p_expWgt            = %expWeight%;
  $$endif.forwardLooking
*
* --- Convert
*
  $$iftheni.task "%task%"=="baseline"
*
*    --- convert bridge-file to GDX container in SAV-directory
*
     $$call "GDXXRW i='reg/%regGtapNameOri%/%BridgeFile%.xlsx' o='sav/%bridgeFile%.gdx' dSetText=Yes index=Layout!B4 MaxDupeErrors=100"
*
*    --- sets and parameters will be read from the GDX container in the SAV directory
*
     $$setglobal readFile %savF%/%bridgeFile%.gdx
     $$ifi not exist %readFile% $$abort GDX file %readFile% not found. Conversion of reg/%regGtapNameOri%/%BridgeFile%.xlsx failed.

     $$onembeddedCode Python:
        import os
        db = gams.ws.add_database_from_gdx(r'%readFile%')
        try:
             ss =  db.get_set('baseYear')
             rec = str(ss.first_record())
             gams.printLog(rec)
             first  = rec.find("(")
             second = rec.find(")")
             os.environ["baseYear"] = rec[first+1:second]
        except:
             os.environ["baseYear"] = "2017"
     $$offEmbeddedCode
     $$setglobal baseYear %sysEnv.baseYear%

  $$else.task
*
*    ---- simulation: sets and parameters will be read from the BAU file generated by a previous
*                     baseline run
*
     $$setglobal readFile %odir%/%bauFile%.gdx
     $$ifi not exist %readFile% $$abort BaU GDX file %readFile% not found
*
*    --- read flag which characterize modules
*        where settings are carried over from the baseline
*        to the simulation. Some other module such as
*        CC damages can be switched on in simulation
*        without being active in baseline mode
*
     $$onmulti
     set tt0;
     $$gdxin %readFile%
       $$loaddc ifForwardLooking,ifVint,ifLabVint,ifEnTech,ifFixPgdpmp,tt0=t0
     $$gdxin
     $$offmulti
*
*    --- use embedded Pyhton to set environment variables
*        depending on wether modules are active or not

     $$onembeddedCode Python:
        import os
        forwardLooking = list(gams.get("ifForwardLooking"))
        os.environ["forwardLooking"] = "off"
        if forwardLooking[0] > 0:
           os.environ["forwardLooking"] = "on"

        vintages = list(gams.get("ifVint"))
        os.environ["vintages"] = "off"
        if vintages[0] > 0:
           os.environ["vintages"] = "on"

        labVintages = list(gams.get("ifLabVint"))
        os.environ["labVintages"] = "off"
        if labVintages[0] > 0:
           os.environ["labVintages"] = "on"

        endoTech = list(gams.get("ifEnTech"))
        os.environ["endoTech"] = "off"
        if endoTech[0] > 0:
           os.environ["endoTech"] = "on"

        ifFixPgdpmp = list(gams.get("ifFixPgdpmp"))
        os.environ["ifFixPgdpmp"] = "off"
        if ifFixPgdpmp[0] > 0:
           os.environ["ifFixPgdpmp"] = "on"

        t0 = list(gams.get("tt0"))
        os.environ["t0"] = str(t0[0])

     $$offembeddedCode

     $$setglobal baseYear %sysEnv.t0%


     $$ifi "%sysEnv.ifFixPgdpmp%"=="on" $setglobal capAccClosure Endogenous with exchange rate and GDP price index fixed

     $$setglobal forwardLooking %sysEnv.forwardLooking%
     $$setglobal vintages       %sysEnv.vintages%
     $$setglobal labVintages    %sysEnv.labVintages%
     $$setglobal endoTech       %sysEnv.endoTech%

  $$endif.task
*
* --- overwrite defaults above with settings from GUI
*
  $$ifi "%CCDamages%"=="on"         ifDmg = 1;
  $$ifi "%CCDamages%"=="off"        ifDmg = 0;

  $$ifi "%ifAirPollDmg%"=="on"      ifAirPollDmg = 1;
  $$ifi "%ifAirPollDmg%"=="off"     ifAirPollDmg = 0;

  $$ifi "%vintages%"=="on"          ifVint = 1;
  $$ifi "%vintages%"=="off"         ifVint = 0;

  $$ifi "%updateOldVintage%"=="off" ifVintUpdate = 0;
  $$ifi "%updateOldVintage%"=="on"  ifVintUpdate = 1;
  $$ifi "%vintages%"=="off"         ifVintUpdate = 0;

  $$ifi "%labVintages%"=="on"       ifLabVint = 1;
  $$ifi "%labVintages%"=="off"      ifLabVint = 0;

  $$ifi "%FiscalResp%"=="on"        ifFiscalResp=1;
  $$ifi "%FiscalResp%"=="off"       ifFiscalResp=0;

  $$iftheni.savf not "%GPDCompSavf%"=="Closure rule"
     $$ifi "%GPDCompNetExports%"=="nominal" $abort "Net exports and foreign savings can't be targeted simultaneously, in file: %system.fn%, line: %system.incline%."
     $$setglobal capAccClosure savfExoRel
  $$endif.savf
*
* --- define the closure rule for foreign savings
*
  acronyms   savfExoRel,savfEndoERFix,savfEndoGtap,savfEndoGTEM,savfEndoUsage,savfEndoResRegSavings;

  scalar capAccClosure; capAccClosure = savfExoRel;
  $$ifi "%capAccClosure%" == "Fixed as nominal GDP Share"                                        capAccClosure = savfExoRel;
  $$ifi "%capAccClosure%" == "Endogenous with exchange rate and GDP price index fixed"           capAccClosure = savfEndoERFix ;
  $$ifi "%capAccClosure%" == "Endogenous driven by expected return to capital and debt to GDP"   capAccClosure = savfEndoGTEM;
  $$ifi "%capAccClosure%" == "Endogenous as in USAGE"                                            capAccClosure = savfEndoUsage;
  $$ifi "%capAccClosure%" == "Endogenous driven by investments not covered by regional savings"  capAccClosure = savfEndoResRegSavings;
  $$ifi "%capAccClosure%" == "Endogenous driven by expected return"                              capAccClosure = savfEndoGtap;

  $$ifi "%capAccClosure%" == "Endogenous with exchange rate and GDP price index fixed"           ifFixPgdpmp = 1;
*
* --- different type of climate damage from Roson and Sartori
*
  $$iftheni.ccDamages "%CCDamages%"=="ON"

     $$setglobal RSCCDamages off
     $$ifi "%useRosonSartoriLabProd%"=="on"        $setglobal RSCCDamages on
     $$ifi "%useRosonSartoriLandStock%"=="on"      $setglobal RSCCDamages on
     $$ifi "%useRosonSartoriEnergyDemand%"=="on"   $setglobal RSCCDamages on
     $$ifi "%useRosonSartoriTourism%"=="on"        $setglobal RSCCDamages on
     $$ifi "%useRosonSartoriCropYields%"=="on"     $setglobal RSCCDamages on
     $$ifi "%useRosonSartoriHealth%"=="on"         $setglobal RSCCDamages on

  $$else.ccDamages
     $$setglobal RSCCDamages off
  $$endif.ccDamages
*
  $$iftheni.task "%task%"=="baseline"
*
*    --- baseline modus: user defines time horizon via interface
*
      $$ifi not set baseYear $setglobal baseYear 2018
      $$ifi not set lastYear $setglobal lastYear 2053
      $$ife %baseYear%>%lastYear% $abort "Illegal year selection: %lastYear% < %baseYear%, in file: %system.fn%, line: %system.incline%"
      $$evalglobal lastSimYear min(%lastSimYear%,%lastYear%)

      $$ifi not set usedAsBaU $$setglobal usedAsBaU "OFF"

      SET tf               "All time"  /2011*%lastYear%,lastT /;
      set           t(tf)  "Total potential simulation horizon" / %baseYear%*%lastYear% /;
      set           tt(t)    "Simulation horizon"                 / %baseYear%*%lastSimYear% /;
      $$iftheni.forwardLooking "%forwardLooking%"=="on"
         $$evalglobal lastIniYear %lastSimYear%+%futureYears%
         set ttCal(t)        "Simulation horizon"                 / %baseYear%*%lastIniYear%/;
      $$else.forwardLooking
         alias(ttCal,tt);
      $$endif.forwardLooking
      set           tCal(t)  "Simulation horizon"                 / %baseYear%*%lastSimYear% /;
      Singleton set t0(t)  "Base year" / %baseYear% /;

      $$iftheni.setBaU "%SIMNAME%" =="BaU"

*         --- bau always needs to be in the sim set to read tables from excel
         SET sim / BaU / ;
      $$else.setBaU
         SET sim /BaU, "%SIMNAME%" /;
      $$endif.setBaU

  $$else.task
*
*    --- simulation modus: sets are loaded from baseline results
*
     set t;
     $$gdxin "%odir%\%bauFile%"
       $$load t
       set tt(t)
       $$load tt
       set ttCal(t)
       $$load ttCal
       singleton set t0(t);
       $$load t0
     $$gdxin
     alias(t,tf);

     $$iftheni.shortRunShock "%shortRunShock%"=="on"
       $$onmulti
         set t /lastT/;
       $$offmulti
     $$endif.shortRunShock

     SET sim / BaU /;
     $$onmulti
         SET sim / "%simName%" /;
     $$offmulti
*
*    --- reset lastSimYear to not exceed simulation period from base line
*
     $$evalglobal  lastSimYear min(%lastSimYear%,%baseYear%+card(tt)-1)
*
  $$endif.task
*
* --- sets used in forward looking mode
*
  alias(t,t1);
  set tNext(t)                      "Next years in forming expectation";
  singleton set tNextFirst(t)       "First year in tNext set";
  singleton set tNextLast(t)        "Last year in tNext set";
  singleton set tNextSndLast(t)     "Secnd last year in tNext set";
  alias(tNext,tNext1);
  set ttt(t);ttt(tt) = YES;

  set tScale(t);tScale(ttCal) = YES;tScale(t0) = YES;
*
* --- maximum number of repeated solve trials
*
  $$ifi not setglobal maxIter $set maxIter 6
  set iter /1*%maxIter%/ ;
*
* ---- general settings: last year, solvetype, option file, if not gicen by GUI
*
  $$ifi not setglobal solveType   $setglobal solveType MCP
  $$ifi not setglobal lastSimYear $setglobal lastSimYear 2053
  $$ifi not "%solveType%"=="MCP"  $setglobal optfile 1
*
* ---- some solver settings for follow-up solves
*
  option cns=conopt4;
  option dnlp=conopt4;
  option MCPRHoldFx=1;
  $$ifi set MCPSolver   option mcp=%MCPSolver%;
  $$ifi set limrow      option limrow=%limRow%;
  $$ifi set limcol      option limcol=%limcol%;

  $$if not errorfree $abort Compilation error after file: %system.fn%
  if ( execerror, abort "Run-Time error in file: %system.fn%, line: %system.incline%");
