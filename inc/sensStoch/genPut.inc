********************************************************************************
$ontext

   CGEBox project

   GAMS file : GENPUT.INC

   @purpose  : Generate put statements in incude files for draw
   @author   : Wolfgang Britz
   @date     : 03.03.19
   @since    :
   @refDoc   :
   @seeAlso  :
   @calledBy : sensitivity.gms

$offtext
********************************************************************************
*
* --- if the parameter to be shock is not known to the master, it will not be known when the include file
*     is read by com_.gms: we need to declare it
*
  $$set known yes
  $$ifi not declared %1 $set known no
  $$ifi not defined  %1 $set known no
  $$ifi not declared %1 put " parameter %1;"/;

  $$onembeddedCode Python:
    import os

    s = "%2"
    gams.printLog(s)
    if s.startswith("("):
       os.environ["arg2"]   = '"'+s[1:-1]+'"'
       os.environ["arg2tl"] = '"'+s[1:-1]+'"'
    elif not s:
       os.environ["arg2"]   = " "
       os.environ["arg2tl"] = " "
    else:
       os.environ["arg2"]   = "%2"
       os.environ["arg2tl"] = "%2.tl"

    s = "%3"
    if s.startswith("("):
       gams.printLog(s)
       os.environ["arg3"]   = '"'+s[1:-1]+'"'
       os.environ["arg3tl"] = '"'+s[1:-1]+'"'
    elif not s:
       os.environ["arg3"]   = " "
       os.environ["arg3tl"] = " "
    else:
       os.environ["arg3"]   = "%3"
       os.environ["arg3tl"] = "%3.tl"

    s = "%4"
    if s.startswith("("):
       os.environ["arg4"]   = '"'+s[1:-1]+'"'
       os.environ["arg4tl"] = '"'+s[1:-1]+'"'
    elif not s:
       os.environ["arg4"]   = " "
       os.environ["arg4tl"] = " "
    else:
       os.environ["arg4"]   = "%4"
       os.environ["arg4tl"] = "%4.tl"

  $$offembeddedCode

  $$ifi "%5"=="mult"  $set operator  *
  $$ifi "%5"=="add"   $set operator  +
  $$ifi "%5"=="set"   $set operator  + 0*

  $$set postFix
  $$if varType %1 $set postFix .fx

  put "$onDotl"/;
  $$iftheni not "%4"==""
*
*    --- following loop (see sensAnalysis\sens_proc) links the linearized factors used by LHS routine
*        on the set curRFactor to link them to the parameter %1 and the three driving sets %sysEnv.arg2%...%sysEnv.arg4%
*

     loop( factor_par_s1_s2_s3(curRFactor,"%1",%sysEnv.arg2%,%sysEnv.arg3%,%sysEnv.arg4%),
          $$iftheni.decl1 "%known%"=="yes"
*
*            -- that write out a GAMS statement x(a,b,c) = draw(...) * x(a,b,c); where draw is the random shock generated by LHS
*
             put " %1%postfix%('",%sysEnv.arg2tl%,"','",%sysEnv.arg3tl%,"','",%sysEnv.arg4tl%,"') =  ",p_draws(draws,curRFactor),"%operator% %1('",%sysEnv.arg2tl%,"','",%sysEnv.arg3tl%,"','",%sysEnv.arg4tl%,"');"/;
          $$else.decl1
*
*            --- the parameter is not declared, hence, there are no values stored on it which could be changed. We simply
*                store the LHS draws (from the linearized) factors on it
*
             put " %1('",%sysEnv.arg2tl%,"','",%sysEnv.arg3tl%,"','",%sysEnv.arg4tl%,"') =  ",p_draws(draws,curRFactor),";"/;
          $$endif.decl1
     );
  $$elseifi not "%3"==""
*
*    --- same as above, third driving set is missing
*
     loop( factor_par_s1_s2_s3(curRFactor,"%1",%sysEnv.arg2%,%sysEnv.arg3%,''),
          $$iftheni.decl1 "%known%"=="yes"
             put " %1%postfix%('",%sysEnv.arg2tl%,"','",%sysEnv.arg3tl%,"') = ",p_draws(draws,curRFactor)," %operator% %1('",%sysEnv.arg2tl%,"','",%sysEnv.arg3tl%,"');"/;
          $$else.decl1
             put " %1('",%sysEnv.arg2tl%,"','",%sysEnv.arg3tl%,"') = ",p_draws(draws,curRFactor),";"/;
          $$endif.decl1
     );
  $$elseifi not "%2"==""
*
*    --- same as above, seconddriving set is missing
*
     loop( factor_par_s1_s2_s3(curRFactor,"%1",%sysEnv.arg2%,'',''),
          $$iftheni.decl1 "%known%"=="yes"
             put " %1%postfix%('",%sysEnv.arg2tl%,"') = ",p_draws(draws,curRFactor)," %operator% %1('",%sysEnv.arg2tl%"');"/;
          $$else.decl1
             put " %1('",%sysEnv.arg2tl%,"') = ",p_draws(draws,curRFactor),";"/;
          $$endif.decl1
     );
  $$else
*
*    --- same as above, first set is empty (generate scalar draws)
*
     loop( factor_par_s1_s2_s3(curRFactor,"%1",'','',''),
          $$iftheni.decl1 "%known%"=="yes"
             put " %1%postfix% = ",p_draws(draws,curRFactor)," %operator% %1;"/;
          $$else.decl1
             put " %1 = ",p_draws(draws,curRFactor),";"/;
          $$endif.decl1
     );
 $$endif
 $$if not errorfree $abort Compilation error after file: %system.fn%
 if ( execerror, abort "Run-Time error in file: %system.fn%, line: %system.incline%");
